// Phase 7: assert.fails in ~{} test block (§19.12.2)
// Should compile clean.

${
  type MathError:enum = { DivideByZero, Overflow }

  function safeDivide(a, b)! -> MathError {
    if (b == 0) {
      fail MathError.DivideByZero
    }
    return a / b
  }
}

<p>Math utils</>

~{ "safe divide tests"
  test "rejects divide by zero" {
    assert.fails safeDivide(10, 0)
  }
  test "succeeds for valid division" {
    let result = safeDivide(10, 2)
    assert result == 5
  }
}
