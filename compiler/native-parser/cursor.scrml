// cursor.scrml — character-stream cursor over source bytes (DD §D4 P5).
//
// PILLAR 5b classification (DD §D1):
//   The cursor's POSITION is STATE — its lifecycle is the entire lex run,
//   it has identity ("where are we?"), it transitions on every advance.
//   Per DD §D4 P5 the canonical form is a V5-strict reactive cell over
//   `{source: string, pos: int}` — engine-shape is NOT required (single
//   "advancing" condition, no transition contract beyond `pos++`).
//
//   The cursor's READS (peekChar, peekStr, charCodeAt-via-source) are
//   CALCULATION — pure functions over (source, pos + k); no condition-
//   dependent dispatch. Per DD §D1 worked example "tokens-at-offset is
//   calculation."
//
// V5-STRICT NOTE: in a fully-scrml-source build the cursor would be:
//
//   <cursor> = { source: "", pos: 0, line: 1, col: 1 }      // declare
//   @cursor.pos = @cursor.pos + 1                           // advance (write)
//   @cursor.source.charAt(@cursor.pos)                      // current (read)
//
// LIVE M1.1 SURFACE (JS-host): a plain object passed by reference, with
// pure-fn read helpers. Mutability of `.pos` mirrors the V5-strict @-cell
// write semantics (the cell IS state; that the live surface uses object
// mutation rather than reactive-cell write is the same M4+ swap concession
// as token.scrml's string-tag).

${
    // Construct a cursor over a source string.
    // Calculation: pure fn from input → starting cursor state.
    export fn makeCursor(source) {
        return {
            source,            // immutable source buffer
            pos:    0,         // current byte offset (advances; the STATE field)
            line:   1,         // 1-based line of pos
            col:    1,         // 1-based column of pos
        }
    }

    // peekChar — calculation (pure fn, no state mutation).
    // Returns the character at `cursor.pos + k`, or "" if past EOF.
    export fn peekChar(cursor, k) {
        const offset = cursor.pos + (k ?? 0)
        if (offset >= cursor.source.length) return ""
        return cursor.source.charAt(offset)
    }

    // peekCharCode — calculation; faster numeric branch (matches Acorn idiom).
    // Returns -1 if past EOF (so callers can use a single numeric compare).
    export fn peekCharCode(cursor, k) {
        const offset = cursor.pos + (k ?? 0)
        if (offset >= cursor.source.length) return -1
        return cursor.source.charCodeAt(offset)
    }

    // peekStr — calculation; multi-character lookahead for keyword/operator
    // disambiguation (e.g., "===", "...", "=>", "**=", "//", "/*").
    export fn peekStr(cursor, n) {
        return cursor.source.substr(cursor.pos, n)
    }

    // isEof — calculation (predicate).
    export fn isEof(cursor) {
        return cursor.pos >= cursor.source.length
    }

    // advance — STATE write: the cursor's position transitions forward.
    // Tracks line/col bookkeeping so spans stay accurate across newlines.
    // Per V5-strict the body would be `@cursor.pos = ...`; the live-surface
    // mutation mirrors that. Returns nothing — the side-effect IS the point
    // (this is the one declared mutation site for cursor position).
    export fn advance(cursor, n) {
        const steps = n ?? 1
        let i = 0
        while (i < steps) {
            if (cursor.pos >= cursor.source.length) return
            const ch = cursor.source.charCodeAt(cursor.pos)
            cursor.pos = cursor.pos + 1
            if (ch == 10) {
                // newline
                cursor.line = cursor.line + 1
                cursor.col = 1
            } else {
                cursor.col = cursor.col + 1
            }
            i = i + 1
        }
    }

    // snapshot — capture a checkpoint (pos/line/col).
    // Per DD §D4 P3, bounded backtracking is `lin`-typed in canonical scrml.
    // Live surface returns a plain {} for lookahead-with-commit patterns.
    export fn snapshot(cursor) {
        return { pos: cursor.pos, line: cursor.line, col: cursor.col }
    }

    // restore — apply a snapshot back to a cursor (STATE write).
    export fn restore(cursor, snap) {
        cursor.pos = snap.pos
        cursor.line = snap.line
        cursor.col = snap.col
    }
}
