// if-as-expr inside ${} in markup parent (§17.6.9 ex 7)
${
    @count: number = 3
}
<program>
    <div>
        ${
            let label = if (@count > 0) {
                lift "Items: " + @count
            } else {
                lift "No items"
            }
            lift <p class="label">${label}/
        }
    </>
</>
