// fail in a function without ! — E-ERROR-001 (§19.3.3)
${
    type PaymentError:enum = { InvalidAmount(msg: string) }
    function charge(amt: number): number {
        if (amt <= 0) fail PaymentError::InvalidAmount("bad")
        return amt
    }
    log(charge(5))
    function log(n: number) { let _ = n }
}
<program>
    <p>ok</>
</>
