<program>
${
    // ---------------------------------------------------------------------------
    // Type System (TS) — Stage 6 of the scrml compiler pipeline.
    //
    // Self-hosted port of compiler/src/type-system.ts.
    //
    // Sub-stages:
    //   TS-A  Scope chain construction + identifier resolution
    //   TS-B  Type registry + struct/enum/DB-schema-derived types + state type registry
    //   TS-C  Pattern matching exhaustiveness checking
    //   TS-F  Pure function (fn) purity constraint verification
    //   TS-G  Linear type enforcement (lin + ~)
    //
    // Input:  { files: FileAST[], protectAnalysis: ProtectAnalysis, routeMap: RouteMap }
    // Output: { files: TypedFileAST[], errors: TSError[] }
    //
    // Exports: TSError, runTS
    // ---------------------------------------------------------------------------

    ^{
        const { getElementShape, getAllElementNames } = await import("../../src/html-elements.js")
    }

    // ---------------------------------------------------------------------------
    // Error type
    // ---------------------------------------------------------------------------

    export class TSError {
        constructor(code, message, span, severity = "error") {
            this.code = code
            this.message = message
            this.span = span
            this.severity = severity
        }
    }

    // ---------------------------------------------------------------------------
    // ResolvedType constructors
    // ---------------------------------------------------------------------------

    fn tPrimitive(name) {
        return { kind: "primitive", name: name }
    }

    fn tStruct(name, fields) {
        return { kind: "struct", name: name, fields: fields }
    }

    fn tEnum(name, variants) {
        return { kind: "enum", name: name, variants: variants }
    }

    fn tArray(element) {
        return { kind: "array", element: element }
    }

    fn tUnion(members) {
        return { kind: "union", members: members }
    }

    fn tAsIs(constraint = null) {
        return { kind: "asIs", constraint: constraint }
    }

    fn tUnknown() {
        return { kind: "unknown" }
    }

    fn tNot() {
        return { kind: "not" }
    }

    fn tSnippet(paramType = null, optional = false) {
        return { kind: "snippet", paramType: paramType, optional: optional }
    }

    fn tState(name, attributes, isHtml = false, rendersToDom = false, constructorBody = null) {
        return { kind: "state", name: name, attributes: attributes, isHtml: isHtml, rendersToDom: rendersToDom, constructorBody: constructorBody }
    }

    fn tError(name, fields) {
        return { kind: "error", name: name, fields: fields }
    }

    // ---------------------------------------------------------------------------
    // Built-in types
    // ---------------------------------------------------------------------------

    const BUILTIN_TYPES = new Map([
        ["number",  tPrimitive("number")],
        ["string",  tPrimitive("string")],
        ["boolean", tPrimitive("boolean")],
        ["bool",    tPrimitive("boolean")],
        ["null",    tPrimitive("null")],
        ["asIs",    tAsIs()],
        ["not",     tNot()],
        ["NetworkError",    tError("NetworkError",    new Map())],
        ["ValidationError", tError("ValidationError", new Map())],
        ["SQLError",        tError("SQLError",        new Map())],
        ["AuthError",       tError("AuthError",       new Map())],
        ["TimeoutError",    tError("TimeoutError",    new Map())],
        ["ParseError",      tError("ParseError",      new Map())],
        ["NotFoundError",   tError("NotFoundError",   new Map())],
        ["ConflictError",   tError("ConflictError",   new Map())],
    ])

    // ---------------------------------------------------------------------------
    // SQLite type mapping
    // ---------------------------------------------------------------------------

    fn mapSqliteType(sqlType, nullable) {
        const upper = (sqlType != null ? sqlType : "").toUpperCase().trim()

        let base
        let warning = false

        if (upper == "INTEGER" || upper == "INT") {
            base = tPrimitive("number")
        } else if (upper == "TEXT" || upper == "CHAR" || upper == "CLOB" || upper == "VARCHAR") {
            base = tPrimitive("string")
        } else if (upper == "REAL" || upper == "FLOA" || upper == "DOUB") {
            base = tPrimitive("number")
        } else if (upper == "BLOB") {
            base = tPrimitive("string")
        } else if (upper == "NULL" || upper == "") {
            base = tAsIs()
        } else {
            if (upper.includes("INT")) {
                base = tPrimitive("number")
            } else if (upper.includes("CHAR") || upper.includes("CLOB") || upper.includes("TEXT")) {
                base = tPrimitive("string")
            } else if (upper.includes("BLOB") || upper == "") {
                base = tAsIs()
                warning = true
            } else if (upper.includes("REAL") || upper.includes("FLOA") || upper.includes("DOUB")) {
                base = tPrimitive("number")
            } else {
                base = tPrimitive("number")
            }
        }

        const type = nullable ? tUnion([base, tNot()]) : base

        return { type: type, warning: warning }
    }

    // ---------------------------------------------------------------------------
    // InitCap algorithm
    // ---------------------------------------------------------------------------

    fn asciiLower(s) {
        let out = ""
        for (const ch of s) {
            const code = ch.charCodeAt(0)
            out += (code >= 65 && code <= 90) ? String.fromCharCode(code + 32) : ch
        }
        return out
    }

    fn asciiCapFirst(s) {
        if (s.length == 0) return s
        const first = s.charCodeAt(0)
        const cap = (first >= 97 && first <= 122)
            ? String.fromCharCode(first - 32)
            : s[0]
        return cap + s.slice(1)
    }

    fn initCap(tableName) {
        const segments = tableName.split("_")

        const parts = []
        for (const seg of segments) {
            if (seg.length == 0) continue
            parts.push(asciiCapFirst(asciiLower(seg)))
        }

        const result = parts.join("")

        if (result.length == 0 || !/^[A-Za-z_][A-Za-z0-9_]*$/.test(result)) {
            return { name: null, error: "E-TYPE-052" }
        }

        return { name: result, error: null }
    }

    // ---------------------------------------------------------------------------
    // Top-level splitter
    // ---------------------------------------------------------------------------

    fn splitTopLevel(s, delimiters) {
        const delimSet = new Set(delimiters)
        const parts = []
        let depth = 0
        let cur = ""

        for (const ch of s) {
            if (ch == "(" || ch == "[" || ch == "{") {
                depth++
                cur += ch
            } else if (ch == ")" || ch == "]" || ch == "}") {
                depth--
                cur += ch
            } else if (depth == 0 && delimSet.has(ch)) {
                parts.push(cur)
                cur = ""
            } else {
                cur += ch
            }
        }

        if (cur.length > 0) parts.push(cur)
        return parts
    }

    // ---------------------------------------------------------------------------
    // Struct body parser
    // ---------------------------------------------------------------------------

    fn parseStructBody(raw, typeRegistry) {
        const fields = new Map()

        let body = raw.trim()
        if (body.startsWith("{")) body = body.slice(1)
        if (body.endsWith("}")) body = body.slice(0, -1)
        body = body.trim()

        if (!body) return fields

        const lines = splitTopLevel(body, [",", "\n"])

        for (const line of lines) {
            const trimmed = line.trim()
            if (!trimmed) continue

            const colonIdx = trimmed.indexOf(":")
            if (colonIdx == -1) continue

            const fieldName = trimmed.slice(0, colonIdx).trim()
            const typeExpr = trimmed.slice(colonIdx + 1).trim()

            if (!fieldName || !/^[A-Za-z_$][A-Za-z0-9_$]*$/.test(fieldName)) continue

            fields.set(fieldName, resolveTypeExpr(typeExpr, typeRegistry))
        }

        return fields
    }

    // ---------------------------------------------------------------------------
    // Enum body parser
    // ---------------------------------------------------------------------------

    fn parseEnumBody(raw, typeRegistry) {
        const variants = []

        let body = raw.trim()
        if (body.startsWith("{")) body = body.slice(1)
        if (body.endsWith("}")) body = body.slice(0, -1)
        body = body.trim()

        if (!body) return variants

        const lines = splitTopLevel(body, ["\n"])

        for (const line of lines) {
            const trimmed = line.trim()
            if (!trimmed) continue

            const parenIdx = trimmed.indexOf("(")

            if (parenIdx == -1) {
                const unitParts = splitTopLevel(trimmed, [","])
                for (const part of unitParts) {
                    let text = part.trim()
                    if (!text) continue

                    let renders = null
                    const rendersIdx = text.indexOf(" renders ")
                    if (rendersIdx != -1) {
                        const markup = text.slice(rendersIdx + " renders ".length).trim()
                        if (markup) renders = { markup: markup }
                        text = text.slice(0, rendersIdx).trim()
                    }

                    const name = text
                    if (!name) continue
                    if (!/^[A-Z][A-Za-z0-9_]*$/.test(name)) continue
                    variants.push({ name: name, payload: null, renders: renders })
                }
            } else {
                const name = trimmed.slice(0, parenIdx).trim()
                if (!/^[A-Z][A-Za-z0-9_]*$/.test(name)) continue

                const closeParenIdx = trimmed.lastIndexOf(")")
                const payloadStr = trimmed.slice(parenIdx + 1, closeParenIdx).trim()
                const payload = new Map()

                if (payloadStr) {
                    const fieldParts = splitTopLevel(payloadStr, [","])
                    for (const fp of fieldParts) {
                        const colonIdx = fp.indexOf(":")
                        if (colonIdx == -1) continue
                        const fieldName = fp.slice(0, colonIdx).trim()
                        const typeExpr = fp.slice(colonIdx + 1).trim()
                        if (fieldName) {
                            payload.set(fieldName, resolveTypeExpr(typeExpr, typeRegistry))
                        }
                    }
                }

                let renders = null
                const afterParen = closeParenIdx != -1 ? trimmed.slice(closeParenIdx + 1).trim() : ""
                if (afterParen.startsWith("renders ")) {
                    const markup = afterParen.slice("renders ".length).trim()
                    if (markup) renders = { markup: markup }
                }

                variants.push({ name: name, payload: payload, renders: renders })
            }
        }

        return variants
    }

    // ---------------------------------------------------------------------------
    // Type expression resolver
    // ---------------------------------------------------------------------------

    fn resolveTypeExpr(expr, typeRegistry) {
        if (!expr) return tAsIs()

        const trimmed = expr.trim()

        if (trimmed.startsWith("(") && trimmed.endsWith(")")) {
            const inner = trimmed.slice(1, -1)
            const arrowIdx = inner.indexOf("->")
            if (arrowIdx != -1) {
                const rhs = inner.slice(arrowIdx + 2).trim()
                return resolveTypeExpr(rhs, typeRegistry)
            }
            return resolveTypeExpr(inner, typeRegistry)
        }

        if (trimmed.includes("|")) {
            const parts = splitTopLevel(trimmed, ["|"])
            if (parts.length > 1) {
                const members = parts.map(function(p) { return resolveTypeExpr(p.trim(), typeRegistry) })
                return tUnion(members)
            }
        }

        if (trimmed.startsWith("!")) {
            return tAsIs()
        }

        if (trimmed.includes("&&")) {
            return tAsIs()
        }

        if (trimmed.endsWith("[]")) {
            const elementExpr = trimmed.slice(0, -2).trim()
            return tArray(resolveTypeExpr(elementExpr, typeRegistry))
        }

        if (trimmed == "snippet") return tSnippet(null, false)
        if (trimmed == "snippet?") return tSnippet(null, true)
        if (trimmed.startsWith("snippet(") && trimmed.endsWith(")")) {
            const inner = trimmed.slice(8, -1)
            const colonIdx = inner.indexOf(":")
            const paramTypeStr = colonIdx != -1 ? inner.slice(colonIdx + 1).trim() : inner.trim()
            return tSnippet(resolveTypeExpr(paramTypeStr, typeRegistry), false)
        }

        if (BUILTIN_TYPES.has(trimmed)) {
            return BUILTIN_TYPES.get(trimmed)
        }

        if (trimmed == "asIs") {
            return tAsIs()
        }

        if (typeRegistry.has(trimmed)) {
            return typeRegistry.get(trimmed)
        }

        return tAsIs()
    }

    // ---------------------------------------------------------------------------
    // Scope chain
    // ---------------------------------------------------------------------------

    class Scope {
        constructor(parent, label = "scope") {
            this.parent = parent
            this.label = label
            this.bindings = new Map()
        }

        bind(name, entry) {
            this.bindings.set(name, entry)
        }

        lookup(name) {
            let scope = this
            while (scope != null) {
                if (scope.bindings.has(name)) return scope.bindings.get(name)
                scope = scope.parent
            }
            return null
        }

        hasOwn(name) {
            return this.bindings.has(name)
        }
    }

    export class ScopeChain {
        constructor() {
            this._global = new Scope(null, "global")
            this._current = this._global

            for (const [name, type] of BUILTIN_TYPES) {
                this._global.bind(name, { kind: "type", resolvedType: type })
            }
        }

        get current() {
            return this._current
        }

        get global() {
            return this._global
        }

        push(label = "scope") {
            const child = new Scope(this._current, label)
            this._current = child
            return child
        }

        pop() {
            if (this._current.parent == null) {
                throw new Error("ScopeChain: cannot pop global scope")
            }
            this._current = this._current.parent
        }

        lookup(name) {
            return this._current.lookup(name)
        }

        bind(name, entry) {
            this._current.bind(name, entry)
        }
    }

    // ---------------------------------------------------------------------------
    // Type registry builder
    // ---------------------------------------------------------------------------

    export function buildTypeRegistry(typeDecls, errors, fileSpan) {
        const registry = new Map(BUILTIN_TYPES)

        for (const decl of typeDecls) {
            if (!decl.name) continue
            registry.set(decl.name, tUnknown())
        }

        for (const decl of typeDecls) {
            if (!decl.name) continue

            if (decl.typeKind == "struct") {
                const fields = parseStructBody(decl.raw != null ? decl.raw : "", registry)
                registry.set(decl.name, tStruct(decl.name, fields))
            } else if (decl.typeKind == "enum") {
                const variants = parseEnumBody(decl.raw != null ? decl.raw : "", registry)
                registry.set(decl.name, tEnum(decl.name, variants))
            } else if (decl.typeKind == "error") {
                const fields = parseStructBody(decl.raw != null ? decl.raw : "", registry)
                for (const fieldName of fields.keys()) {
                    if (fieldName == "message" || fieldName == "type") {
                        errors.push(new TSError(
                            "E-ERROR-008",
                            "E-ERROR-008: User-defined error type '" + decl.name + "' declares a field named '" + fieldName + "'. " +
                            "The fields 'message' and 'type' are implicit on all error types (\u00a719.3) and may not be declared.",
                            fileSpan,
                        ))
                    }
                }
                registry.set(decl.name, tError(decl.name, fields))
            } else {
                registry.set(decl.name, tAsIs())
            }
        }

        for (const decl of typeDecls) {
            if (!decl.name) continue
            const existing = registry.get(decl.name)
            if (!existing) continue

            if (decl.typeKind == "struct" && existing.kind == "struct") {
                const fields = parseStructBody(decl.raw != null ? decl.raw : "", registry)
                registry.set(decl.name, tStruct(decl.name, fields))
            } else if (decl.typeKind == "enum" && existing.kind == "enum") {
                const variants = parseEnumBody(decl.raw != null ? decl.raw : "", registry)
                registry.set(decl.name, tEnum(decl.name, variants))
            } else if (decl.typeKind == "error" && existing.kind == "error") {
                const fields = parseStructBody(decl.raw != null ? decl.raw : "", registry)
                registry.set(decl.name, tError(decl.name, fields))
            }
        }

        return registry
    }

    // ---------------------------------------------------------------------------
    // State type registry
    // ---------------------------------------------------------------------------

    export function buildStateTypeRegistry() {
        const registry = new Map()

        for (const tagName of getAllElementNames()) {
            const shape = getElementShape(tagName)
            if (!shape) continue
            registry.set(tagName, tState(
                tagName,
                shape.attributes,
                shape.rendersToDom,
                shape.rendersToDom,
                null,
            ))
        }

        return registry
    }

    export function registerStateType(registry, name, attributes, rendersToDom, constructorBody, errors, span) {
        if (getElementShape(name) != null) {
            errors.push(new TSError(
                "E-STATE-005",
                "E-STATE-005: State type name `" + name + "` collides with a built-in HTML element name. " +
                "Choose a different name for your state type.",
                span,
            ))
            return false
        }

        const existing = registry.get(name)
        if (existing && !existing.isHtml) {
            errors.push(new TSError(
                "E-STATE-006",
                "E-STATE-006: Duplicate state type definition for `" + name + "`. " +
                "A state type with this name is already defined.",
                span,
            ))
            return false
        }

        registry.set(name, tState(name, attributes, false, rendersToDom, constructorBody))
        return true
    }

    export function getStateType(registry, name) {
        return registry.get(name) != null ? registry.get(name) : null
    }

    // ---------------------------------------------------------------------------
    // DB-schema type generator
    // ---------------------------------------------------------------------------

    export function generateDbTypes(dbTypeViews, stateBlockId, blockSpan, userTypeRegistry) {
        const errors = []
        const generatedNames = new Map()

        if (!dbTypeViews || !dbTypeViews.tables) {
            return { generatedNames: generatedNames, errors: errors }
        }

        const seenNamesThisBlock = new Map()

        for (const [tableName, tableTypeView] of dbTypeViews.tables) {
            const initCapResult = initCap(tableName)
            const generatedName = initCapResult.name
            const initCapError = initCapResult.error

            if (initCapError) {
                errors.push(new TSError(
                    "E-TYPE-052",
                    "E-TYPE-052: Table name `" + tableName + "` produces an invalid scrml identifier after the InitCap algorithm. " +
                    "Table names must produce valid identifiers (beginning with an ASCII letter or underscore, " +
                    "containing only alphanumeric characters and underscores). Got: \"" + tableName + "\".",
                    blockSpan,
                ))
                continue
            }

            if (seenNamesThisBlock.has(generatedName)) {
                const otherTable = seenNamesThisBlock.get(generatedName)
                errors.push(new TSError(
                    "E-TYPE-050",
                    "E-TYPE-050: Tables `" + otherTable + "` and `" + tableName + "` in the same `< db>` block " +
                    "both produce the generated type name `" + generatedName + "`. Rename one of the tables to resolve the collision.",
                    blockSpan,
                ))
                continue
            }

            if (userTypeRegistry && userTypeRegistry.has(generatedName) &&
                !BUILTIN_TYPES.has(generatedName)) {
                errors.push(new TSError(
                    "E-TYPE-050",
                    "E-TYPE-050: The generated type name `" + generatedName + "` (from table `" + tableName + "`) " +
                    "collides with a user-declared type. Rename the table or the user-declared type.",
                    blockSpan,
                ))
            }

            seenNamesThisBlock.set(generatedName, tableName)

            const fullFields = new Map()
            for (const col of (tableTypeView.fullSchema != null ? tableTypeView.fullSchema : [])) {
                const mapResult = mapSqliteType(col.sqlType, col.nullable)
                const type = mapResult.type
                const warning = mapResult.warning
                if (warning) {
                    errors.push(new TSError(
                        "E-TYPE-051",
                        "E-TYPE-051: Column `" + col.name + "` in table `" + tableName + "` has type " +
                        "`" + col.sqlType + "` which is not mappable after the SQLite affinity algorithm. " +
                        "The column has been typed as `asIs`. Declare an explicit type or use a recognized SQLite type.",
                        blockSpan,
                        "warning",
                    ))
                }
                fullFields.set(col.name, type)
            }
            const fullType = tStruct(generatedName, fullFields)

            const clientFields = new Map()
            for (const col of (tableTypeView.clientSchema != null ? tableTypeView.clientSchema : [])) {
                const mapResult = mapSqliteType(col.sqlType, col.nullable)
                clientFields.set(col.name, mapResult.type)
            }
            const clientType = tStruct(generatedName, clientFields)

            generatedNames.set(generatedName, { fullType: fullType, clientType: clientType })
        }

        return { generatedNames: generatedNames, errors: errors }
    }

    // ---------------------------------------------------------------------------
    // Node key
    // ---------------------------------------------------------------------------

    fn nodeKey(node) {
        if (node.id != null) return String(node.id)
        if (node.span) {
            const s = node.span
            return s.start + "-" + s.end
        }
        return "node-" + Math.random()
    }

    // ---------------------------------------------------------------------------
    // Attribute validation helpers
    // ---------------------------------------------------------------------------

    export function inferAttrValueType(value) {
        if (!value) return null

        if (value.kind == "string-literal" || typeof value == "string") return "string"
        if (value.kind == "number-literal") return "number"
        if (value.kind == "boolean-literal") return "boolean"

        return null
    }

    export function validateMarkupAttributes(node, stateType, errors, filePath) {
        const attrs = node.attrs
        if (!Array.isArray(attrs) || attrs.length == 0) return

        const shape = stateType.attributes
        if (!shape || !(shape instanceof Map)) return

        for (const attr of attrs) {
            if (!attr || !attr.name) continue
            const attrName = attr.name
            const defaultSpan = { file: filePath, start: 0, end: 0, line: 1, col: 1 }
            const attrSpan = attr.span != null ? attr.span : (node.span != null ? node.span : defaultSpan)

            if (attrName == "ref") continue
            if (attrName.startsWith("bind:")) continue
            if (attrName.startsWith("class:")) continue

            const shapeDef = shape.get(attrName)

            if (shapeDef) {
                const valueType = inferAttrValueType(attr.value)
                if (valueType && shapeDef.type != valueType) {
                    errors.push(new TSError(
                        "E-MARKUP-002",
                        "E-MARKUP-002: Attribute `" + attrName + "` on <" + node.name + "> expects type `" + shapeDef.type + "` " +
                        "but received `" + valueType + "`.",
                        attrSpan,
                    ))
                }
            } else {
                if (stateType.isHtml) {
                    const isDataAttr = attrName.startsWith("data-")
                    const isAriaAttr = attrName.startsWith("aria-")
                    if (isDataAttr || isAriaAttr) {
                        errors.push(new TSError(
                            "E-MARKUP-003",
                            "E-MARKUP-003: Custom attribute `" + attrName + "` on <" + node.name + ">.",
                            attrSpan,
                            "warning",
                        ))
                    } else {
                        errors.push(new TSError(
                            "E-MARKUP-003",
                            "E-MARKUP-003: Unknown attribute `" + attrName + "` on HTML element <" + node.name + ">. " +
                            "This attribute is not in the HTML specification for this element.",
                            attrSpan,
                        ))
                    }
                } else {
                    errors.push(new TSError(
                        "E-STATE-004",
                        "E-STATE-004: Unknown attribute `" + attrName + "` on state type <" + node.name + ">. " +
                        "The state type `" + node.name + "` does not define an attribute named `" + attrName + "`.",
                        attrSpan,
                    ))
                }
            }
        }
    }

    // ---------------------------------------------------------------------------
    // Node annotator
    // ---------------------------------------------------------------------------

    function annotateNodes(fileAST, scopeChain, typeRegistry, routeMap, protectAnalysis, generatedTypesByScopeId, errors, stateTypeRegistry) {
        const nodeTypes = new Map()
        const filePath = fileAST.filePath

        function functionBoundary(fnNode) {
            if (!routeMap || !routeMap.functions) return "client"
            const id = filePath + "::" + (fnNode.span != null ? fnNode.span.start : undefined)
            const entry = routeMap.functions.get(id)
            return entry ? entry.boundary : "client"
        }

        const fnErrorTypes = new Map()
        const fnCanFail = new Set()
        const fnAllDeclared = new Set()

        function collectFnErrorTypes(nodes) {
            for (const n of nodes) {
                if (n.kind == "function-decl" && n.name) {
                    fnAllDeclared.add(n.name)
                    if (n.canFail == true) {
                        fnCanFail.add(n.name)
                        if (n.errorType) {
                            fnErrorTypes.set(n.name, n.errorType)
                        }
                    }
                }
                const body = n.body
                if (Array.isArray(body)) collectFnErrorTypes(body)
                const children = n.children
                if (Array.isArray(children)) collectFnErrorTypes(children)
            }
        }

        const topLevelNodes = fileAST.nodes != null ? fileAST.nodes : []
        collectFnErrorTypes(topLevelNodes)

        function visitNode(node) {
            if (!node || typeof node != "object") return tUnknown()

            const n = node
            const key = nodeKey(n)
            let resolvedType

            const nodeKind = n.kind

            if (nodeKind == "markup") {
                const attrs = n.attrs
                if (Array.isArray(attrs)) {
                    for (const attr of attrs) {
                        visitAttr(attr, n)
                    }
                }

                if (stateTypeRegistry && n.name && !n.isComponent) {
                    const stateType = stateTypeRegistry.get(n.name)
                    if (stateType) {
                        validateMarkupAttributes(n, stateType, errors, filePath)
                    }
                }

                if (Array.isArray(attrs)) {
                    for (const attr of attrs) {
                        if (attr && attr.name == "ref" && attr.value && attr.value.kind == "variable-ref") {
                            const refVarName = attr.value.name.replace(/^@/, "")
                            const elemShape = getElementShape(n.name != null ? n.name : "")
                            if (elemShape && elemShape.domInterface) {
                                scopeChain.bind(refVarName, {
                                    kind: "ref-binding",
                                    resolvedType: tUnion([tPrimitive(elemShape.domInterface), tPrimitive("null")]),
                                    domInterface: elemShape.domInterface,
                                })
                            } else {
                                scopeChain.bind(refVarName, {
                                    kind: "ref-binding",
                                    resolvedType: tUnion([tPrimitive("Element"), tPrimitive("null")]),
                                    domInterface: "Element",
                                })
                            }
                        }
                    }
                }

                const children = n.children
                if (Array.isArray(children)) {
                    for (const child of children) {
                        if (child.kind == "logic") {
                            const logicBody = child.body
                            if (Array.isArray(logicBody)) {
                                for (const stmt of logicBody) {
                                    if (
                                        stmt.kind == "match-stmt" &&
                                        stmt.partial == true
                                    ) {
                                        errors.push(new TSError(
                                            "E-TYPE-081",
                                            "E-TYPE-081: `partial match` is not valid in a rendering context. " +
                                            "A `partial match` inside a markup interpolation (`${}`) would silently produce " +
                                            "no output for unhandled variants, making it indistinguishable from a missing case. " +
                                            "Use standard `match` with an `else` arm that renders nothing for variants you want to skip.",
                                            stmt.span,
                                        ))
                                    }
                                }
                            }
                        }
                        visitNode(child)
                    }
                }
                resolvedType = { kind: "html-element", tag: n.name != null ? n.name : "unknown", attrs: {} }

            } else if (nodeKind == "state") {
                scopeChain.push("state:" + (n.stateType != null ? n.stateType : "unknown"))

                if (n.stateType == "db") {
                    const stateBlockId = filePath + "::" + (n.span != null ? n.span.start : undefined)
                    const genMap = generatedTypesByScopeId.get(stateBlockId)
                    if (genMap) {
                        for (const [name, genEntry] of genMap) {
                            scopeChain.bind(name, {
                                kind: "db-type",
                                resolvedType: genEntry.clientType,
                                fullType: genEntry.fullType,
                                clientType: genEntry.clientType,
                            })
                        }
                    }
                }

                const stateChildren = n.children
                if (Array.isArray(stateChildren)) {
                    for (const child of stateChildren) visitNode(child)
                }

                scopeChain.pop()
                resolvedType = tAsIs()

            } else if (nodeKind == "state-constructor-def") {
                const ctorName = n.stateType != null ? n.stateType : "unknown"
                scopeChain.push("state-ctor:" + ctorName)

                if (stateTypeRegistry && Array.isArray(n.typedAttrs)) {
                    const attrMap = new Map()
                    for (const ta of n.typedAttrs) {
                        attrMap.set(ta.name, {
                            type: ta.typeExpr,
                            required: !ta.optional,
                            default: ta.defaultValue,
                        })
                    }

                    const ctorSpan = n.span != null ? n.span : { file: filePath, start: 0, end: 0, line: 1, col: 1 }
                    registerStateType(
                        stateTypeRegistry,
                        ctorName,
                        attrMap,
                        false,
                        n.children != null ? n.children : null,
                        errors,
                        ctorSpan,
                    )

                    for (const ta of n.typedAttrs) {
                        scopeChain.bind(ta.name, {
                            kind: "state-attr",
                            resolvedType: resolveTypeExpr(ta.typeExpr, typeRegistry) != null ? resolveTypeExpr(ta.typeExpr, typeRegistry) : tAsIs(),
                        })
                    }
                }

                const ctorChildren = n.children
                if (Array.isArray(ctorChildren)) {
                    for (const child of ctorChildren) visitNode(child)
                }

                scopeChain.pop()
                resolvedType = tState(ctorName, new Map(), false, false, n.children != null ? n.children : null)

            } else if (nodeKind == "logic") {
                const body = n.body
                if (Array.isArray(body)) {
                    for (const stmt of body) visitNode(stmt)
                }
                resolvedType = tAsIs()

            } else if (nodeKind == "function-decl") {
                const boundary = functionBoundary(n)

                scopeChain.push("fn:" + (n.name != null ? n.name : "anon") + ":" + boundary)

                if (Array.isArray(n.params)) {
                    for (const param of n.params) {
                        const paramName = typeof param == "string" ? param : param.name
                        if (paramName) {
                            scopeChain.bind(paramName, { kind: "variable", resolvedType: tAsIs() })
                        }
                    }
                }

                const fnBody = n.body
                if (Array.isArray(fnBody)) {
                    for (const stmt of fnBody) visitLogicNode(stmt, boundary)
                }

                scopeChain.pop()

                const fnType = { kind: "function", name: n.name != null ? n.name : "", params: [], returnType: tAsIs() }
                if (n.name) {
                    scopeChain.bind(n.name, {
                        kind: "function",
                        resolvedType: fnType,
                        isPure: false,
                    })
                }

                if (Array.isArray(fnBody)) {
                    const canFail = n.canFail == true
                    const fnName = n.name != null ? n.name : "<anonymous>"
                    for (const stmt of fnBody) {
                        if (!stmt) continue
                        if (stmt.kind == "fail-expr" && !canFail) {
                            errors.push(new TSError(
                                "E-ERROR-001",
                                "E-ERROR-001: 'fail' used in function '" + fnName + "' which is not declared as failable. " +
                                "Add '!' to the function signature: 'function " + fnName + "(...)! -> {ErrorType}'.",
                                (stmt.span != null ? stmt.span : n.span),
                            ))
                        }
                        if (stmt.kind == "propagate-expr" && !canFail) {
                            errors.push(new TSError(
                                "E-ERROR-003",
                                "E-ERROR-003: '?' propagation operator used in function '" + fnName + "' which is not declared as failable. " +
                                "Add '!' to the function signature or handle the error with 'match' or '!{}'.",
                                (stmt.span != null ? stmt.span : n.span),
                            ))
                        }
                        if (stmt.kind == "propagate-expr" && canFail) {
                            const calleeRaw = stmt.expr != null ? stmt.expr : ""
                            const calleeMatch = /^([A-Za-z_$][A-Za-z0-9_$]*)/.exec(calleeRaw)
                            const calleeName = calleeMatch ? calleeMatch[1] : null
                            if (calleeName && fnAllDeclared.has(calleeName) && !fnCanFail.has(calleeName)) {
                                errors.push(new TSError(
                                    "E-ERROR-004",
                                    "E-ERROR-004: '?' applied to call to '" + calleeName + "' which is not a failable function. " +
                                    "Only '!' functions can be propagated with '?'.",
                                    (stmt.span != null ? stmt.span : n.span),
                                ))
                            }
                        }
                    }
                    for (const stmt of fnBody) {
                        if (!stmt || stmt.kind != "bare-expr") continue
                        const exprRaw = stmt.expr != null ? stmt.expr : ""
                        const bareCallMatch = /^([A-Za-z_$][A-Za-z0-9_$]*)\s*\(/.exec(exprRaw)
                        const bareCallee = bareCallMatch ? bareCallMatch[1] : null
                        if (bareCallee && fnCanFail.has(bareCallee)) {
                            errors.push(new TSError(
                                "E-ERROR-002",
                                "E-ERROR-002: Result of failable function '" + bareCallee + "' is not handled. " +
                                "Either match the result, propagate with '?', catch with '!{}', or wrap in '<errorBoundary>'.",
                                (stmt.span != null ? stmt.span : n.span),
                            ))
                        }
                    }
                }

                if (n.fnKind == "fn" && Array.isArray(fnBody)) {
                    checkFnBodyProhibitions(n, fnBody, errors, filePath, stateTypeRegistry)
                }

                resolvedType = fnType

            } else if (nodeKind == "type-decl") {
                if (n.name && typeRegistry.has(n.name)) {
                    resolvedType = typeRegistry.get(n.name)
                    scopeChain.bind(n.name, { kind: "type", resolvedType: resolvedType })
                } else {
                    resolvedType = tAsIs()
                }

            } else if (nodeKind == "let-decl" || nodeKind == "const-decl") {
                resolvedType = tAsIs()
                if (n.name) {
                    scopeChain.bind(n.name, { kind: "variable", resolvedType: resolvedType })
                }

            } else if (nodeKind == "reactive-decl") {
                resolvedType = tAsIs()
                if (n.name) {
                    scopeChain.bind("@" + n.name, { kind: "reactive", resolvedType: resolvedType })
                    scopeChain.bind(n.name, { kind: "reactive", resolvedType: resolvedType })
                }

            } else if (nodeKind == "bare-expr") {
                resolvedType = tAsIs()

            } else if (nodeKind == "sql") {
                resolvedType = tAsIs()

            } else if (nodeKind == "css-inline") {
                resolvedType = { kind: "cssClass" }

            } else if (nodeKind == "meta") {
                scopeChain.push("meta")
                const metaBody = n.body
                if (Array.isArray(metaBody)) {
                    for (const stmt of metaBody) visitNode(stmt)
                }
                scopeChain.pop()
                resolvedType = { kind: "meta-splice", resultType: tAsIs(), parentContext: "meta" }

            } else if (nodeKind == "text") {
                resolvedType = tPrimitive("string")

            } else if (nodeKind == "comment") {
                resolvedType = tAsIs()

            } else if (nodeKind == "import-decl" || nodeKind == "export-decl") {
                resolvedType = tAsIs()

            } else if (nodeKind == "component-def") {
                resolvedType = tAsIs()

            } else if (nodeKind == "guarded-expr") {
                const guardedNode = n.guardedNode
                const errorArms = n.arms != null ? n.arms : []

                if (guardedNode) visitNode(guardedNode)

                let calleeExpr = null
                if (guardedNode) {
                    if (guardedNode.kind == "bare-expr" && typeof guardedNode.expr == "string") {
                        calleeExpr = guardedNode.expr.trim()
                    } else if (
                        (guardedNode.kind == "let-decl" || guardedNode.kind == "const-decl") &&
                        typeof guardedNode.init == "string"
                    ) {
                        calleeExpr = guardedNode.init.trim()
                    }
                }

                let calleeName = null
                if (calleeExpr) {
                    const calleeMatch = /^([A-Za-z_$][A-Za-z0-9_$]*)/.exec(calleeExpr)
                    if (calleeMatch) calleeName = calleeMatch[1]
                }

                const errorTypeName = calleeName ? (fnErrorTypes.get(calleeName) != null ? fnErrorTypes.get(calleeName) : null) : null

                if (errorTypeName) {
                    const errorEnumType = typeRegistry.get(errorTypeName)
                    if (errorEnumType && errorEnumType.kind == "enum") {
                        const enumType = errorEnumType
                        const allVariants = (enumType.variants != null ? enumType.variants : []).map(function(v) { return v.name })

                        const hasWildcard = errorArms.some(function(a) { return a.pattern == "_" || a.pattern == "else" })

                        if (!hasWildcard && allVariants.length > 0) {
                            const handledVariants = new Set()
                            for (const arm of errorArms) {
                                const p = arm.pattern != null ? arm.pattern : ""
                                if (p != "_" && p != "else") {
                                    const variantName = p.replace(/^::/, "").replace(/^\./, "")
                                    if (variantName) handledVariants.add(variantName)
                                }
                            }

                            const missing = allVariants.filter(function(v) { return !handledVariants.has(v) })
                            if (missing.length > 0) {
                                errors.push(new TSError(
                                    "E-TYPE-080",
                                    "E-TYPE-080: Non-exhaustive error handler for `" + errorTypeName + "`. " +
                                    "Missing variant(s): " + missing.join(", ") + ". " +
                                    "Add the missing arms or use `else =>` to handle all remaining variants.",
                                    n.span,
                                ))
                            }
                        }
                    }
                }

                resolvedType = tAsIs()

            } else if (nodeKind == "error-effect") {
                resolvedType = tAsIs()

            } else if (nodeKind == "style") {
                resolvedType = { kind: "cssClass" }
                const styleChildren = n.children
                if (Array.isArray(styleChildren)) {
                    for (const child of styleChildren) visitNode(child)
                }

            } else if (nodeKind == "lift-expr") {
                const liftExpr = n.expr
                if (liftExpr && liftExpr.kind == "expr" && typeof liftExpr.expr == "string") {
                    if (/^\s*partial\s+match/.test(liftExpr.expr)) {
                        errors.push(new TSError(
                            "E-TYPE-081",
                            "E-TYPE-081: `partial match` is not valid in a rendering context. " +
                            "A `partial match` in a `lift` expression would silently produce no output for " +
                            "unhandled variants, making it indistinguishable from a missing case. " +
                            "Use standard `match` with an `else` arm that renders nothing for variants you want to skip: `else => \"\"`.",
                            n.span,
                        ))
                    }
                }
                resolvedType = tAsIs()

            } else if (nodeKind == "while-stmt" || nodeKind == "if-stmt") {
                const condStr = (n.condition != null ? n.condition : "").trim()
                if (condStr.length > 0) {
                    const inner = (condStr.startsWith("(") && condStr.endsWith(")"))
                        ? condStr.slice(1, -1).trim()
                        : condStr
                    const ASSIGN_ROOT_RE = /^[@A-Za-z_$][A-Za-z0-9_$@.]*\s*=[^=]/
                    if (ASSIGN_ROOT_RE.test(inner)) {
                        const stmtKind = n.kind == "while-stmt" ? "while" : "if"
                        const condLine = n.span != null ? n.span.line : 1
                        errors.push(new TSError(
                            "W-ASSIGN-001",
                            "W-ASSIGN-001: Assignment (`=`) used as the condition of `" + stmtKind + "` at line " + condLine + ".\n" +
                            "  Did you mean `==` for equality comparison?\n" +
                            "  If assignment is intentional, use double parentheses to signal intent:\n\n" +
                            "    " + stmtKind + " ((" + inner.trim() + ")) { ... }\n",
                            n.span != null ? n.span : { file: filePath, start: 0, end: 0, line: condLine, col: 1 },
                            "warning",
                        ))
                    }
                }
                const stmtBody = n.body
                if (Array.isArray(stmtBody)) {
                    for (const child of stmtBody) visitNode(child)
                }
                const stmtConsequent = n.consequent
                if (Array.isArray(stmtConsequent)) {
                    for (const child of stmtConsequent) visitNode(child)
                }
                const stmtAlternate = n.alternate
                if (Array.isArray(stmtAlternate)) {
                    for (const child of stmtAlternate) visitNode(child)
                }
                resolvedType = tAsIs()

            } else {
                for (const k of Object.keys(n)) {
                    if (k == "span" || k == "id") continue
                    const val = n[k]
                    if (Array.isArray(val)) {
                        for (const child of val) {
                            if (child && typeof child == "object" && child.kind) visitNode(child)
                        }
                    }
                }
                resolvedType = tAsIs()
            }

            nodeTypes.set(key, resolvedType)
            return resolvedType
        }

        function visitLogicNode(node, boundary) {
            if (!node || typeof node != "object") return

            const key = nodeKey(node)

            if (node.kind == "bare-expr") {
                nodeTypes.set(key, tAsIs())
                return
            }

            if (node.kind == "function-decl") {
                visitNode(node)
                return
            }

            visitNode(node)
        }

        function visitAttr(attr, parent) {
            if (!attr || !attr.value) return

            const value = attr.value

            if (value.kind == "variable-ref") {
                const name = value.name
                const entry = scopeChain.lookup(name)
                if (!entry) {
                    const defaultSpan = { file: filePath, start: 0, end: 0, line: 1, col: 1 }
                    const attrSpan = value.span != null ? value.span : (attr.span != null ? attr.span : (parent != null ? parent.span : defaultSpan))
                    errors.push(new TSError(
                        "E-SCOPE-001",
                        "E-SCOPE-001: Unquoted identifier `" + name + "` in attribute `" + attr.name + "` " +
                        "cannot be resolved in the current scope.",
                        attrSpan != null ? attrSpan : defaultSpan,
                    ))
                }
            }
        }

        const allTopNodes = fileAST.nodes != null ? fileAST.nodes : []
        for (const node of allTopNodes) {
            visitNode(node)
        }

        const typeDeclNodes = fileAST.typeDecls != null ? fileAST.typeDecls : []
        for (const node of typeDeclNodes) {
            const key = nodeKey(node)
            if (!nodeTypes.has(key)) {
                visitNode(node)
            }
        }

        return nodeTypes
    }

    // ---------------------------------------------------------------------------
    // Not-type utilities
    // ---------------------------------------------------------------------------

    export function isOptionalType(type) {
        if (!type) return false
        if (type.kind == "not") return true
        if (type.kind == "unknown" || type.kind == "asIs") return true
        if (type.kind == "union") {
            return type.members.some(function(m) { return m.kind == "not" })
        }
        return false
    }

    export function checkNotAssignment(targetType, varName) {
        if (isOptionalType(targetType)) return null
        const typeName = targetType.kind == "primitive" ? targetType.name : targetType.kind
        return "E-TYPE-041: Cannot assign `not` to variable `" + varName + "` of type `" + typeName + "`. " +
            "Declare the type as `" + typeName + " | not` to allow absence values (\u00a742)."
    }

    export function checkNotReturn(returnType, fnName) {
        if (isOptionalType(returnType)) return null
        const typeName = returnType.kind == "primitive" ? returnType.name : returnType.kind
        return "E-TYPE-043: Function `" + fnName + "` has return type `" + typeName + "` but may return `not`. " +
            "Declare the return type as `" + typeName + " | not` to allow absence return values (\u00a742)."
    }

    // ---------------------------------------------------------------------------
    // Struct field access checker
    // ---------------------------------------------------------------------------

    export function checkStructFieldAccess(expr, scopeChain, typeRegistry, span, errors) {
        if (!expr || typeof expr != "string") return

        const MEMBER_RE = /\b([A-Za-z_$][A-Za-z0-9_$]*)\.([A-Za-z_$][A-Za-z0-9_$]*)\b/g
        let m

        while ((m = MEMBER_RE.exec(expr)) != null) {
            const objName = m[1]
            const fieldName = m[2]

            const entry = scopeChain.lookup(objName)
            if (!entry) continue

            const type = entry.resolvedType
            if (!type || type.kind != "struct") continue

            if (!type.fields || !type.fields.has(fieldName)) {
                const availFields = type.fields ? [...type.fields.keys()].join(", ") : "(none)"
                errors.push(new TSError(
                    "E-TYPE-004",
                    "E-TYPE-004: Struct type `" + type.name + "` does not have a field named `" + fieldName + "`. " +
                    "Available fields: " + availFields + ".",
                    span,
                ))
            }
        }
    }

    // ---------------------------------------------------------------------------
    // TS-C: Exhaustiveness checker
    // ---------------------------------------------------------------------------

    export function checkEnumExhaustiveness(enumType, armPatterns) {
        const allVariants = new Set((enumType.variants != null ? enumType.variants : []).map(function(v) { return v.name }))
        const coveredVariants = new Set()
        const duplicateArms = []
        let hasWildcard = false

        for (const pattern of armPatterns) {
            if (pattern.kind == "wildcard") {
                hasWildcard = true
                break
            }
            if (pattern.kind == "variant") {
                const name = pattern.variantName
                if (coveredVariants.has(name)) {
                    duplicateArms.push(name)
                } else {
                    coveredVariants.add(name)
                }
            }
        }

        const missing = hasWildcard
            ? []
            : [...allVariants].filter(function(v) { return !coveredVariants.has(v) })

        const unreachableWildcard = hasWildcard && coveredVariants.size >= allVariants.size

        return { missing: missing, unreachableWildcard: unreachableWildcard, duplicateArms: duplicateArms }
    }

    export function checkUnionExhaustiveness(unionType, armPatterns) {
        const memberNames = new Set()
        for (const member of (unionType.members != null ? unionType.members : [])) {
            if (member.kind == "primitive") {
                memberNames.add(member.name)
            } else if (member.kind == "enum") {
                memberNames.add(member.name)
            } else if (member.kind == "asIs") {
                memberNames.add("asIs")
            } else {
                memberNames.add(member.kind)
            }
        }

        const coveredMembers = new Set()
        let hasWildcard = false

        for (const pattern of armPatterns) {
            if (pattern.kind == "wildcard") {
                hasWildcard = true
                break
            }
            if (pattern.kind == "is-type") {
                coveredMembers.add(pattern.typeName)
            }
        }

        const missing = hasWildcard
            ? []
            : [...memberNames].filter(function(m) { return !coveredMembers.has(m) })

        const unreachableWildcard = hasWildcard && coveredMembers.size >= memberNames.size

        return { missing: missing, unreachableWildcard: unreachableWildcard }
    }

    export function checkExhaustiveness(matchNode, subjectType, matchSpan, errors, isPartial = false) {
        const arms = matchNode.arms != null ? matchNode.arms : []
        const armPatterns = arms.map(function(arm) { return arm.pattern != null ? arm.pattern : { kind: "wildcard" } })

        if (subjectType.kind == "enum") {
            const result = checkEnumExhaustiveness(subjectType, armPatterns)
            const missing = result.missing
            const unreachableWildcard = result.unreachableWildcard
            const duplicateArms = result.duplicateArms

            for (const variantName of duplicateArms) {
                errors.push(new TSError(
                    "E-TYPE-023",
                    "E-TYPE-023: Duplicate match arm for variant `::"+variantName+"`. " +
                    "The second arm for `" + variantName + "` can never be reached. Remove the duplicate arm.",
                    matchSpan,
                ))
            }

            if (missing.length > 0 && !isPartial) {
                errors.push(new TSError(
                    "E-TYPE-020",
                    "E-TYPE-020: Non-exhaustive match over enum type `" + subjectType.name + "`. " +
                    "Missing variants: " + missing.map(function(v) { return "::" + v }).join(", ") + ". " +
                    "Add explicit arms for the missing variants or add a `_` wildcard arm.",
                    matchSpan,
                ))
            }

            if (isPartial && missing.length == 0 && !unreachableWildcard) {
                errors.push(new TSError(
                    "W-MATCH-003",
                    "W-MATCH-003: `partial` is unnecessary — all variants of `" + subjectType.name + "` are explicitly covered. " +
                    "Remove `partial` to use standard exhaustive match, which will catch future variant additions.",
                    matchSpan,
                    "warning",
                ))
            }

            if (unreachableWildcard) {
                errors.push(new TSError(
                    "W-MATCH-001",
                    "W-MATCH-001: Wildcard `_` arm is unreachable. All variants of `" + subjectType.name + "` " +
                    "are already covered by explicit arms. Remove the `_` arm.",
                    matchSpan,
                    "warning",
                ))
            }
        } else if (subjectType.kind == "union") {
            const result = checkUnionExhaustiveness(subjectType, armPatterns)
            const missing = result.missing
            const unreachableWildcard = result.unreachableWildcard

            if (isPartial && missing.length == 0 && !unreachableWildcard) {
                errors.push(new TSError(
                    "W-MATCH-003",
                    "W-MATCH-003: `partial` is unnecessary — all union members are explicitly covered. " +
                    "Remove `partial` to use standard exhaustive match, which will catch future member additions.",
                    matchSpan,
                    "warning",
                ))
            }

            if (missing.length > 0 && !isPartial) {
                const unionHasNot = subjectType.members != null
                    ? subjectType.members.some(function(m) { return m.kind == "not" })
                    : false
                const missingNot = missing.includes("not")
                if (unionHasNot && missingNot) {
                    errors.push(new TSError(
                        "E-MATCH-012",
                        "E-MATCH-012: Match on `T | not` type lacks a `not` arm and lacks an `else`/wildcard arm. " +
                        "Add a `not => ...` arm or an `_ => ...` wildcard to handle the absence case (\u00a742).",
                        matchSpan,
                    ))
                    const otherMissing = missing.filter(function(m) { return m != "not" })
                    if (otherMissing.length > 0) {
                        errors.push(new TSError(
                            "E-TYPE-006",
                            "E-TYPE-006: Non-exhaustive match over union type. " +
                            "Missing members: " + otherMissing.join(", ") + ". " +
                            "Add explicit arms for the missing members or add a `_` wildcard arm.",
                            matchSpan,
                        ))
                    }
                } else {
                    errors.push(new TSError(
                        "E-TYPE-006",
                        "E-TYPE-006: Non-exhaustive match over union type. " +
                        "Missing members: " + missing.join(", ") + ". " +
                        "Add explicit arms for the missing members or add a `_` wildcard arm.",
                        matchSpan,
                    ))
                }
            }

            if (unreachableWildcard) {
                errors.push(new TSError(
                    "W-MATCH-001",
                    "W-MATCH-001: Wildcard `_` arm is unreachable. All members of the union type " +
                    "are already covered by explicit arms. Remove the `_` arm.",
                    matchSpan,
                    "warning",
                ))
            }
        }
    }

    // ---------------------------------------------------------------------------
    // TS-G: Linear type classes
    // ---------------------------------------------------------------------------

    export class LinTracker {
        constructor() {
            this._vars = new Map()
            this._firstUseSpan = new Map()
        }

        declare(name) {
            this._vars.set(name, "unconsumed")
            this._firstUseSpan.delete(name)
        }

        consume(name, span) {
            if (!this._vars.has(name)) return null

            const state = this._vars.get(name)
            if (state == "consumed") {
                return {
                    code: "E-LIN-002",
                    varName: name,
                    span: this._firstUseSpan.get(name) != null ? this._firstUseSpan.get(name) : span,
                    secondUseSpan: span,
                }
            }

            this._vars.set(name, "consumed")
            this._firstUseSpan.set(name, span)
            return null
        }

        forceConsume(name, span) {
            this._vars.set(name, "consumed")
            if (span) this._firstUseSpan.set(name, span)
        }

        has(name) { return this._vars.has(name) }

        isUnconsumed(name) { return this._vars.get(name) == "unconsumed" }

        names() { return [...this._vars.keys()] }

        unconsumedNames() {
            return [...this._vars.entries()]
                .filter(function(entry) { return entry[1] == "unconsumed" })
                .map(function(entry) { return entry[0] })
        }

        consumedNames() {
            return [...this._vars.entries()]
                .filter(function(entry) { return entry[1] == "consumed" })
                .map(function(entry) { return entry[0] })
        }

        snapshot() { return new Map(this._vars) }

        restore(snap) { this._vars = new Map(snap) }
    }

    export class MustUseTracker {
        constructor() {
            this._vars = new Map()
            this._declSpans = new Map()
        }

        declare(name, span) {
            this._vars.set(name, "unused")
            if (span) this._declSpans.set(name, span)
        }

        markUsed(name) {
            if (this._vars.has(name)) {
                this._vars.set(name, "used")
            }
        }

        has(name) { return this._vars.has(name) }

        names() { return [...this._vars.keys()] }

        unusedEntries() {
            return [...this._vars.entries()]
                .filter(function(entry) { return entry[1] == "unused" })
                .map(function(entry) { return { name: entry[0], span: this._declSpans.get(entry[0]) } }.bind(this))
        }

        scanExpression(exprStr) {
            if (!exprStr || typeof exprStr != "string") return
            for (const name of this._vars.keys()) {
                if (this._vars.get(name) == "used") continue
                const re = new RegExp("\\b" + escapeForRegex(name) + "\\b")
                if (re.test(exprStr)) {
                    this._vars.set(name, "used")
                }
            }
        }
    }

    fn escapeForRegex(s) {
        return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
    }

    export class TildeTracker {
        constructor() {
            this._state = "uninitialized"
            this._initSpan = null
        }

        initialize(span, elide = false) {
            if (this._state == "initialized" && !elide) {
                const err = { code: "E-TILDE-002", span: this._initSpan != null ? this._initSpan : span }
                this._initSpan = span
                return err
            }
            this._state = "initialized"
            this._initSpan = span
            return null
        }

        consume(span) {
            if (this._state == "uninitialized") {
                return { code: "E-TILDE-001", span: span }
            }
            this._state = "uninitialized"
            this._initSpan = null
            return null
        }

        isInitialized() { return this._state == "initialized" }

        snapshot() {
            return { state: this._state, initSpan: this._initSpan }
        }

        restore(snap) {
            this._state = snap.state
            this._initSpan = snap.initSpan
        }
    }

    // ---------------------------------------------------------------------------
    // Loop body scanner
    // ---------------------------------------------------------------------------

    export function hasNonLiftTildeConsumer(nodes) {
        if (!Array.isArray(nodes)) return false

        for (const node of nodes) {
            if (!node || typeof node != "object") continue

            if (node.kind == "tilde-ref") return true

            if (node.kind == "lift-stmt") continue

            for (const key of Object.keys(node)) {
                if (key == "span" || key == "id") continue
                const val = node[key]
                if (Array.isArray(val) && hasNonLiftTildeConsumer(val)) return true
            }
        }

        return false
    }

    // ---------------------------------------------------------------------------
    // TS-G: checkLinear
    // ---------------------------------------------------------------------------

    export function checkLinear(body, errors, opts = {}) {
        const parentLinTracker = opts.linTracker != null ? opts.linTracker : null
        const parentTildeTracker = opts.tildeTracker != null ? opts.tildeTracker : null
        const parentMustUseTracker = opts.mustUseTracker != null ? opts.mustUseTracker : null
        const inLoop = opts.inLoop != null ? opts.inLoop : false
        const file = opts.file != null ? opts.file : "/unknown"

        const linTracker = new LinTracker()
        const tildeTracker = parentTildeTracker != null ? parentTildeTracker : new TildeTracker()
        const mustUseTracker = new MustUseTracker()

        function mkSpan() {
            return { file: file, start: 0, end: 0, line: 1, col: 1 }
        }

        function emitLinError(desc, contextSpan) {
            const s = desc.span != null ? desc.span : (contextSpan != null ? contextSpan : mkSpan())
            if (desc.code == "E-LIN-002") {
                errors.push(new TSError(
                    "E-LIN-002",
                    "E-LIN-002: Linear variable `" + desc.varName + "` consumed more than once. " +
                    "First use at col " + (s.col != null ? s.col : "?") + "; second use at col " + (desc.secondUseSpan != null ? desc.secondUseSpan.col : "?") + ".",
                    s,
                ))
            } else if (desc.code == "E-LIN-001") {
                errors.push(new TSError(
                    "E-LIN-001",
                    "E-LIN-001: Linear variable `" + desc.varName + "` declared but never consumed before scope exit.",
                    s,
                ))
            } else if (desc.code == "E-LIN-003") {
                errors.push(new TSError(
                    "E-LIN-003",
                    "E-LIN-003: Linear variable `" + desc.varName + "` is consumed in some branches but not others. " +
                    "All branches must consume the same set of lin variables.",
                    s,
                ))
            }
        }

        function emitTildeError(desc, contextSpan) {
            const s = desc.span != null ? desc.span : (contextSpan != null ? contextSpan : mkSpan())
            if (desc.code == "E-TILDE-001") {
                errors.push(new TSError("E-TILDE-001", "E-TILDE-001: `~` referenced but not initialized.", s))
            } else if (desc.code == "E-TILDE-002") {
                errors.push(new TSError("E-TILDE-002", "E-TILDE-002: `~` initialized but not consumed before next initialization or scope exit.", s))
            }
        }

        function walkNode(node, lt, tt, loop) {
            if (!node || typeof node != "object") return

            const kind = node.kind

            if (kind == "lin-decl") {
                lt.declare(node.name)

            } else if (kind == "tilde-decl") {
                mustUseTracker.declare(node.name, node.span)
                if (node.init) {
                    mustUseTracker.scanExpression(node.init)
                    if (parentMustUseTracker) parentMustUseTracker.scanExpression(node.init)
                }

            } else if (kind == "lin-ref") {
                const name = node.name
                const tracker = lt.has(name) ? lt : (parentLinTracker && parentLinTracker.has(name) ? parentLinTracker : null)
                if (tracker) {
                    if (loop) {
                        errors.push(new TSError(
                            "E-LIN-002",
                            "E-LIN-002: Linear variable `" + name + "` consumed inside a loop. " +
                            "Loop iteration count is unprovable; consume `" + name + "` before or after the loop.",
                            (node.span != null ? node.span : mkSpan()),
                        ))
                    } else {
                        const err = tracker.consume(name, (node.span != null ? node.span : mkSpan()))
                        if (err) emitLinError(err, node.span)
                    }
                }

            } else if (kind == "tilde-init") {
                const err = tt.initialize(node.span)
                if (err) emitTildeError(err, node.span)

            } else if (kind == "tilde-ref") {
                const err = tt.consume(node.span)
                if (err) emitTildeError(err, node.span)

            } else if (kind == "lift-stmt") {
                if (node.usesTilde) {
                    const consumeErr = tt.consume(node.span)
                    if (consumeErr) emitTildeError(consumeErr, node.span)
                }
                const initErr = tt.initialize(node.span, false)
                if (initErr) emitTildeError(initErr, node.span)

            } else if (kind == "if-stmt") {
                const linSnap = lt.snapshot()
                const tildeSnap = tt.snapshot()

                for (const n of (node.consequent != null ? node.consequent : [])) walkNode(n, lt, tt, loop)
                const afterConsequent = lt.snapshot()
                const afterConsequentTilde = tt.snapshot()

                lt.restore(linSnap)
                tt.restore(tildeSnap)
                const hasAlternate = Array.isArray(node.alternate) && node.alternate.length > 0
                if (hasAlternate) {
                    for (const n of node.alternate) walkNode(n, lt, tt, loop)
                }
                const afterAlternate = lt.snapshot()

                const allVars = new Set([...afterConsequent.keys(), ...afterAlternate.keys()])
                let allSymmetric = true

                for (const varName of allVars) {
                    const inConsequent = afterConsequent.get(varName) == "consumed"
                    const inAlternate = hasAlternate
                        ? afterAlternate.get(varName) == "consumed"
                        : linSnap.get(varName) == "consumed"

                    if (inConsequent != inAlternate) {
                        allSymmetric = false
                        errors.push(new TSError(
                            "E-LIN-003",
                            "E-LIN-003: Linear variable `" + varName + "` is consumed in some branches but not others. " +
                            "All branches must consume the same set of lin variables.",
                            (node.span != null ? node.span : mkSpan()),
                        ))
                    }
                }

                if (allSymmetric && allVars.size > 0) {
                    for (const varName of allVars) {
                        if (afterConsequent.get(varName) == "consumed") {
                            lt.forceConsume(varName, node.span)
                        }
                    }
                } else {
                    lt.restore(linSnap)
                }

                tt.restore(afterConsequentTilde)

            } else if (kind == "match-stmt") {
                const arms = node.arms != null ? node.arms : []
                if (arms.length == 0) {
                    // nothing to do
                } else {
                    const preMatchSnap = lt.snapshot()
                    const preMatchTilde = tt.snapshot()
                    const armSnapshots = []

                    for (const arm of arms) {
                        lt.restore(preMatchSnap)
                        tt.restore(preMatchTilde)
                        for (const n of (arm.body != null ? arm.body : [])) walkNode(n, lt, tt, loop)
                        armSnapshots.push(lt.snapshot())
                    }

                    if (armSnapshots.length > 0) {
                        const refSnap = armSnapshots[0]
                        const allVars = new Set(preMatchSnap.keys())

                        for (const varName of allVars) {
                            const refConsumed = refSnap.get(varName) == "consumed"
                            let symmetric = true
                            for (let i = 1; i < armSnapshots.length; i++) {
                                if ((armSnapshots[i].get(varName) == "consumed") != refConsumed) {
                                    symmetric = false
                                    break
                                }
                            }
                            if (!symmetric) {
                                errors.push(new TSError(
                                    "E-LIN-003",
                                    "E-LIN-003: Linear variable `" + varName + "` is consumed in some match arms but not others. " +
                                    "All arms must consume the same set of lin variables.",
                                    (node.span != null ? node.span : mkSpan()),
                                ))
                            }
                        }

                        lt.restore(refSnap)
                    }

                    tt.restore(preMatchTilde)
                }

            } else if (kind == "for-loop" || kind == "while-loop") {
                const loopBody = node.body != null ? node.body : []
                const elide = !hasNonLiftTildeConsumer(loopBody)
                walkLoopBody(loopBody, lt, tt, elide)

            } else if (kind == "closure") {
                const captures = node.captures != null ? node.captures : []
                for (const captureName of captures) {
                    mustUseTracker.markUsed(captureName)
                    if (parentMustUseTracker) parentMustUseTracker.markUsed(captureName)

                    const tracker = lt.has(captureName) ? lt : (parentLinTracker && parentLinTracker.has(captureName) ? parentLinTracker : null)
                    if (tracker) {
                        if (loop) {
                            errors.push(new TSError(
                                "E-LIN-002",
                                "E-LIN-002: Linear variable `" + captureName + "` captured by closure inside a loop. " +
                                "Loop iteration count is unprovable.",
                                (node.span != null ? node.span : mkSpan()),
                            ))
                        } else {
                            const err = tracker.consume(captureName, (node.span != null ? node.span : mkSpan()))
                            if (err) emitLinError(err, node.span)
                        }
                    }
                }
                checkLinear(node.body != null ? node.body : [], errors, { linTracker: lt, mustUseTracker: mustUseTracker, inLoop: false, file: file })

            } else {
                const body = node.body
                if (Array.isArray(body)) {
                    for (const n of body) walkNode(n, lt, tt, loop)
                }
                const children = node.children
                if (Array.isArray(children)) {
                    for (const n of children) walkNode(n, lt, tt, loop)
                }
            }

            scanNodeExpressions(node)
        }

        function scanNodeExpressions(node) {
            const fields = [node.expr, node.init, node.value, node.condition, node.test]
            for (const field of fields) {
                if (typeof field == "string") {
                    mustUseTracker.scanExpression(field)
                    if (parentMustUseTracker) parentMustUseTracker.scanExpression(field)
                }
            }
        }

        function walkLoopBody(loopBody, lt, tt, elide) {
            if (!Array.isArray(loopBody)) return
            for (const node of loopBody) {
                if (!node || typeof node != "object") continue

                if (node.kind == "lift-stmt" && elide) {
                    if (node.usesTilde) {
                        const consumeErr = tt.consume(node.span)
                        if (consumeErr) emitTildeError(consumeErr, node.span)
                    }
                    tt.initialize(node.span, true)
                    continue
                }

                walkNode(node, lt, tt, true)
            }
        }

        if (!Array.isArray(body)) return

        for (const node of body) {
            walkNode(node, linTracker, tildeTracker, inLoop)
        }

        for (const varName of linTracker.unconsumedNames()) {
            errors.push(new TSError(
                "E-LIN-001",
                "E-LIN-001: Linear variable `" + varName + "` declared but never consumed before scope exit.",
                mkSpan(),
            ))
        }

        for (const entry of mustUseTracker.unusedEntries()) {
            errors.push(new TSError(
                "E-MU-001",
                "E-MU-001: Variable `" + entry.name + "` was declared but never used before this scope closes. " +
                "Either use the value somewhere (e.g., pass it to a function or reference it in a template), " +
                "or prefix with `const` if you don't need the must-use guarantee.",
                entry.span != null ? entry.span : mkSpan(),
            ))
        }

        const lastNode = Array.isArray(body) ? body[body.length - 1] : null
        const lastWasElisionLoop = lastNode &&
            (lastNode.kind == "for-loop" || lastNode.kind == "while-loop") &&
            !hasNonLiftTildeConsumer(lastNode.body != null ? lastNode.body : [])
        if (tildeTracker.isInitialized() && !parentTildeTracker && !lastWasElisionLoop) {
            errors.push(new TSError(
                "E-TILDE-002",
                "E-TILDE-002: `~` initialized but not consumed before scope exit.",
                tildeTracker._initSpan != null ? tildeTracker._initSpan : mkSpan(),
            ))
        }
    }

    // ---------------------------------------------------------------------------
    // Overload registry
    // ---------------------------------------------------------------------------

    export function buildOverloadRegistry(fileAST) {
        const registry = new Map()

        function visit(node) {
            if (!node || typeof node != "object") return
            const n = node

            if (n.kind == "function-decl" && n.stateTypeScope) {
                const fnName = n.name
                const stateType = n.stateTypeScope
                if (fnName) {
                    if (!registry.has(fnName)) registry.set(fnName, new Map())
                    registry.get(fnName).set(stateType, n)
                }
            }

            if (Array.isArray(n.children)) {
                for (const child of n.children) visit(child)
            }
            if (Array.isArray(n.body)) {
                for (const stmt of n.body) visit(stmt)
            }
            if (Array.isArray(n.nodes)) {
                for (const node2 of n.nodes) visit(node2)
            }
            if (n.ast && Array.isArray(n.ast.nodes)) {
                for (const node2 of n.ast.nodes) visit(node2)
            }
        }

        const nodes = fileAST.nodes != null ? fileAST.nodes : (fileAST.ast != null ? fileAST.ast.nodes : [])
        for (const node of (nodes != null ? nodes : [])) visit(node)

        for (const [fnName, overloads] of registry) {
            if (overloads.size < 2) registry.delete(fnName)
        }

        return registry
    }

    // ---------------------------------------------------------------------------
    // Loop control flow validation
    // ---------------------------------------------------------------------------

    fn checkLoopControl(nodes, errors, filePath) {
        const LOOP_KINDS = new Set(["for-stmt", "while-stmt", "do-while-stmt", "for-loop", "while-loop"])
        const FN_KINDS = new Set(["function-decl", "fn-decl", "fn", "function", "closure"])

        function mkSpan(node) {
            return node.span != null ? node.span : { file: filePath, start: 0, end: 0, line: 1, col: 1 }
        }

        function walk(body, loopDepth, insideFn) {
            for (const node of body) {
                if (!node || typeof node != "object") continue
                walkNode(node, loopDepth, insideFn)
            }
        }

        function walkNode(node, loopDepth, insideFn) {
            if (!node || typeof node != "object") return
            const kind = node.kind

            if (kind == "break-stmt") {
                if (loopDepth == 0) {
                    const s = mkSpan(node)
                    errors.push(new TSError(
                        "E-LOOP-001",
                        "E-LOOP-001: `break` at line " + s.line + " is not inside any loop. " +
                        "`break` may only appear inside a `while`, `do...while`, or `for...of` loop body. " +
                        "Remove `break` or move it inside a loop.",
                        s,
                    ))
                }
                return
            }

            if (kind == "continue-stmt") {
                if (loopDepth == 0) {
                    const s = mkSpan(node)
                    errors.push(new TSError(
                        "E-LOOP-002",
                        "E-LOOP-002: `continue` at line " + s.line + " is not inside any loop. " +
                        "`continue` may only appear inside a `while`, `do...while`, or `for...of` loop body. " +
                        "Remove `continue` or move it inside a loop.",
                        s,
                    ))
                }
                return
            }

            if (LOOP_KINDS.has(kind)) {
                const loopBody = node.body != null ? node.body : []
                walk(loopBody, loopDepth + 1, insideFn)
                return
            }

            if (FN_KINDS.has(kind)) {
                const fnBody = node.body != null ? node.body : []
                walk(fnBody, 0, false)
                return
            }

            const nodeBody = node.body
            if (Array.isArray(nodeBody)) walk(nodeBody, loopDepth, insideFn)

            const consequent = node.consequent
            if (Array.isArray(consequent)) walk(consequent, loopDepth, insideFn)

            const alternate = node.alternate
            if (Array.isArray(alternate)) walk(alternate, loopDepth, insideFn)

            const arms = node.arms
            if (Array.isArray(arms)) {
                for (const arm of arms) {
                    const armBody = arm.body
                    if (Array.isArray(armBody)) walk(armBody, loopDepth, insideFn)
                }
            }

            const children = node.children
            if (Array.isArray(children)) walk(children, loopDepth, insideFn)
        }

        walk(nodes, 0, false)
    }

    // ---------------------------------------------------------------------------
    // fn body prohibition checks
    // ---------------------------------------------------------------------------

    fn checkFnBodyProhibitions(fnNode, body, errors, filePath, stateTypeRegistry) {
        const fnName = fnNode.name != null ? fnNode.name : "<anonymous>"
        const fnSpan = fnNode.span != null ? fnNode.span : { file: filePath, start: 0, end: 0, line: 1, col: 1 }

        if (fnNode.isAsync || fnNode.async) {
            errors.push(new TSError(
                "E-FN-005",
                "E-FN-005: `fn " + fnName + "` is declared `async`. `fn` is always synchronous. " +
                "Perform the `await` at the call site and pass the resolved value as a parameter to `fn`.",
                fnSpan,
            ))
        }

        const NON_DET_CALLS = [
            "Date.now",
            "new Date",
            "Math.random",
            "crypto.randomUUID",
            "crypto.getRandomValues",
            "performance.now",
        ]

        const DOM_MUTATION_APIS = [
            "document.createElement",
            "document.getElementById",
            "document.querySelector",
            "document.querySelectorAll",
            "document.body",
            "document.head",
            ".appendChild",
            ".removeChild",
            ".insertBefore",
            ".setAttribute",
            ".innerHTML",
            ".innerText",
            ".textContent",
            ".removeAttribute",
        ]

        function nodeText(node) {
            const parts = []
            if (typeof node.value == "string") parts.push(node.value)
            if (typeof node.expr == "string") parts.push(node.expr)
            if (typeof node.text == "string") parts.push(node.text)
            if (typeof node.raw == "string") parts.push(node.raw)
            if (typeof node.callee == "string") parts.push(node.callee)
            if (typeof node.name == "string") parts.push(node.name)
            if (typeof node.left == "string") parts.push(node.left)
            if (typeof node.right == "string") parts.push(node.right)
            if (typeof node.target == "string") parts.push(node.target)
            return parts.join(" ")
        }

        const localNames = new Set()

        if (Array.isArray(fnNode.params)) {
            for (const param of fnNode.params) {
                const paramName = typeof param == "string" ? param : param.name
                if (paramName) localNames.add(paramName)
            }
        }

        function collectLocalDecls(nodes) {
            for (const stmt of nodes) {
                if (!stmt || typeof stmt != "object") continue
                if (stmt.kind == "function-decl") continue
                const declName = stmt.name
                if (
                    declName &&
                    (stmt.kind == "let-decl" ||
                     stmt.kind == "const-decl" ||
                     stmt.kind == "lin-decl" ||
                     stmt.kind == "variable-decl" ||
                     stmt.kind == "tilde-decl")
                ) {
                    localNames.add(declName)
                }
                if (Array.isArray(stmt.body)) collectLocalDecls(stmt.body)
                if (Array.isArray(stmt.then)) collectLocalDecls(stmt.then)
                if (Array.isArray(stmt.else)) collectLocalDecls(stmt.else)
                if (Array.isArray(stmt.consequent)) collectLocalDecls(stmt.consequent)
                if (Array.isArray(stmt.alternate)) collectLocalDecls(stmt.alternate)
            }
        }
        collectLocalDecls(body)

        const ASSIGN_RE = /([A-Za-z_$][A-Za-z0-9_$]*)(?:\.[A-Za-z_$][A-Za-z0-9_$]*)?\s*=[^=>]/

        function checkOuterScopeMutation(stmt, txt) {
            const stmtSpan = stmt.span != null ? stmt.span : fnSpan
            if (stmt.kind == "assignment") {
                const targetName = stmt.target != null ? stmt.target : stmt.name
                if (targetName && !localNames.has(targetName)) {
                    errors.push(new TSError(
                        "E-FN-003",
                        "E-FN-003: `fn " + fnName + "` body writes to `" + targetName + "` at line " + stmtSpan.line + ", " +
                        "which is declared outside the `fn` boundary. " +
                        "`fn` may not mutate outer-scope variables. " +
                        "Declare `" + targetName + "` inside the `fn` body, or pass it as a parameter and return an updated value alongside the state.",
                        stmtSpan,
                    ))
                }
                return
            }
            if (txt) {
                const match = ASSIGN_RE.exec(txt)
                if (match) {
                    const targetName = match[1]
                    if (targetName && !localNames.has(targetName)) {
                        errors.push(new TSError(
                            "E-FN-003",
                            "E-FN-003: `fn " + fnName + "` body writes to `" + targetName + "` at line " + stmtSpan.line + ", " +
                            "which is declared outside the `fn` boundary. " +
                            "`fn` may not mutate outer-scope variables. " +
                            "Declare `" + targetName + "` inside the `fn` body, or pass it as a parameter and return an updated value alongside the state.",
                            stmtSpan,
                        ))
                    }
                }
            }
        }

        const stateInstances = new Map()
        const loadedFields = new Map()
        const returnTypes = []
        let hasFnLocalTilde = false
        let hasLiftInBody = false
        let liftSpan = null

        for (const stmt of body) {
            if (!stmt || typeof stmt != "object") continue
            if (stmt.kind == "tilde-decl" || stmt.kind == "tilde-stmt") {
                hasFnLocalTilde = true
            }
        }

        function collectStateInstances(nodes) {
            for (const stmt of nodes) {
                if (!stmt || typeof stmt != "object") continue
                if (stmt.kind == "function-decl") continue

                if (stmt.kind == "state-instantiation" || stmt.kind == "state-init") {
                    const varName = stmt.name
                    const typeName = stmt.stateType != null ? stmt.stateType : (stmt.typeName != null ? stmt.typeName : stmt.type)
                    if (varName && typeName) {
                        stateInstances.set(varName, typeName)
                        loadedFields.set(varName, new Set())
                    }
                }

                if (
                    stmt.kind == "let-decl" ||
                    stmt.kind == "const-decl" ||
                    stmt.kind == "variable-decl"
                ) {
                    const varName = stmt.name
                    const stateTypeName = stmt.stateType != null ? stmt.stateType : stmt.instanceOf
                    if (varName && stateTypeName) {
                        stateInstances.set(varName, stateTypeName)
                        loadedFields.set(varName, new Set())
                    } else if (varName && typeof stmt.value == "string") {
                        const stateMatch = /^\s*<\s*([A-Z][A-Za-z0-9_]*)\s*>\s*$/.exec(stmt.value)
                        if (stateMatch) {
                            const stateTypeParsed = stateMatch[1]
                            stateInstances.set(varName, stateTypeParsed)
                            loadedFields.set(varName, new Set())
                        }
                    }
                }
            }
        }
        collectStateInstances(body)

        const FIELD_ASSIGN_RE = /\b([A-Za-z_$][A-Za-z0-9_$]*)\s*\.\s*([A-Za-z_$][A-Za-z0-9_$]*)\s*=[^=>]/

        function trackFieldAssignment(txt) {
            const match = FIELD_ASSIGN_RE.exec(txt)
            if (match) {
                const varName = match[1]
                const fieldName = match[2]
                const fields = loadedFields.get(varName)
                if (fields) {
                    fields.add(fieldName)
                }
            }
        }

        function collectReturnTypes(nodes, isBranch) {
            for (const stmt of nodes) {
                if (!stmt || typeof stmt != "object") continue
                if (stmt.kind == "function-decl") continue

                if (stmt.kind == "return-stmt") {
                    const returnValue = stmt.value != null ? stmt.value : (stmt.expr != null ? stmt.expr : stmt.expression)
                    if (returnValue && typeof returnValue == "string") {
                        const instance = stateInstances.get(returnValue.trim())
                        if (instance && isBranch) {
                            const retSpan = stmt.span != null ? stmt.span : fnSpan
                            returnTypes.push({ typeName: instance, line: retSpan.line })
                        }
                    }
                    const retType = stmt.returnType != null ? stmt.returnType : stmt.stateType
                    if (retType && isBranch) {
                        const retSpan = stmt.span != null ? stmt.span : fnSpan
                        returnTypes.push({ typeName: retType, line: retSpan.line })
                    }
                }

                const branchNodes = []
                if (Array.isArray(stmt.then)) branchNodes.push(stmt.then)
                if (Array.isArray(stmt.else)) branchNodes.push(stmt.else)
                if (Array.isArray(stmt.consequent)) branchNodes.push(stmt.consequent)
                if (Array.isArray(stmt.alternate)) branchNodes.push(stmt.alternate)
                if (Array.isArray(stmt.arms)) {
                    for (const arm of stmt.arms) {
                        if (Array.isArray(arm.body)) branchNodes.push(arm.body)
                    }
                }
                for (const branch of branchNodes) {
                    collectReturnTypes(branch, true)
                }
            }
        }
        collectReturnTypes(body, false)

        function walkBody(nodes) {
            for (const stmt of nodes) {
                if (!stmt || typeof stmt != "object") continue

                const stmtSpan = stmt.span != null ? stmt.span : fnSpan

                if (stmt.kind == "sql") {
                    errors.push(new TSError(
                        "E-FN-001",
                        "E-FN-001: `fn " + fnName + "` body contains a `?{}` SQL access. " +
                        "`fn` is a pure function and may not perform database operations. " +
                        "Move the `?{}` query outside `fn` and pass the result as a parameter.",
                        stmtSpan,
                    ))
                }

                if (stmt.kind == "await-expr" || stmt.await == true) {
                    errors.push(new TSError(
                        "E-FN-005",
                        "E-FN-005: `fn " + fnName + "` body contains `await`. " +
                        "`fn` is always synchronous. Perform the `await` at the call site and pass the resolved value as a parameter.",
                        stmtSpan,
                    ))
                }

                if (stmt.kind == "lift" || stmt.kind == "lift-stmt") {
                    hasLiftInBody = true
                    if (!liftSpan) liftSpan = stmtSpan
                }

                const txt = nodeText(stmt)
                if (txt) {
                    for (const nd of NON_DET_CALLS) {
                        if (txt.includes(nd)) {
                            errors.push(new TSError(
                                "E-FN-004",
                                "E-FN-004: `fn " + fnName + "` body calls `" + nd + "()`, which is non-deterministic. " +
                                "`fn` must be a pure function of its inputs. Generate the value outside `fn` and pass it as a parameter.",
                                stmtSpan,
                            ))
                            break
                        }
                    }

                    for (const domApi of DOM_MUTATION_APIS) {
                        if (txt.includes(domApi)) {
                            errors.push(new TSError(
                                "E-FN-002",
                                "E-FN-002: `fn " + fnName + "` body contains a DOM mutation call (`" + domApi + "`). " +
                                "`fn` is a pure function and may not mutate the DOM. " +
                                "Use `<state>` fields to hold configuration data; let the runtime render the DOM from state.",
                                stmtSpan,
                            ))
                            break
                        }
                    }

                    checkOuterScopeMutation(stmt, txt)
                    trackFieldAssignment(txt)
                }

                if (stmt.kind == "return-stmt" && stateTypeRegistry) {
                    const returnValue = stmt.value != null ? stmt.value : (stmt.expr != null ? stmt.expr : stmt.expression)
                    const returnVarName = typeof returnValue == "string" ? returnValue.trim() : null
                    if (returnVarName) {
                        const typeName = stateInstances.get(returnVarName)
                        if (typeName) {
                            const stateType = stateTypeRegistry.get(typeName)
                            if (stateType && stateType.attributes) {
                                const loaded = loadedFields.get(returnVarName) != null ? loadedFields.get(returnVarName) : new Set()
                                for (const [fieldName] of stateType.attributes) {
                                    if (!loaded.has(fieldName)) {
                                        errors.push(new TSError(
                                            "E-FN-006",
                                            "E-FN-006: `fn` returns `" + returnVarName + "` (type `" + typeName + "`) " +
                                            "at line " + stmtSpan.line + " with field `" + fieldName + "` unassigned. " +
                                            "All fields of a `<state>` type must be assigned before the object is returned from `fn`. " +
                                            "Assign `" + returnVarName + "." + fieldName + "` before the `return` statement.",
                                            stmtSpan,
                                        ))
                                    }
                                }
                            }
                        }
                    }
                }

                if (stmt.kind == "function-decl") continue

                if (Array.isArray(stmt.body)) walkBody(stmt.body)
                if (Array.isArray(stmt.children)) walkBody(stmt.children)
                if (Array.isArray(stmt.consequent)) walkBody(stmt.consequent)
                if (Array.isArray(stmt.alternate)) walkBody(stmt.alternate)
                if (Array.isArray(stmt.then)) walkBody(stmt.then)
                if (Array.isArray(stmt.else)) walkBody(stmt.else)
                if (Array.isArray(stmt.arms)) {
                    for (const arm of stmt.arms) {
                        if (Array.isArray(arm.body)) walkBody(arm.body)
                    }
                }
            }
        }

        walkBody(body)

        if (returnTypes.length >= 2) {
            const uniqueTypes = [...new Set(returnTypes.map(function(r) { return r.typeName }))]
            if (uniqueTypes.length > 1) {
                const hasExplicitUnionReturn =
                    typeof fnNode.returnType == "string" && fnNode.returnType.includes("|")
                if (!hasExplicitUnionReturn) {
                    const firstRet = returnTypes[0]
                    const fallbackSecondType = uniqueTypes.length > 1 ? uniqueTypes[uniqueTypes.length - 1] : ""
                    const secondRet = returnTypes.find(function(r) { return r.typeName != firstRet.typeName })
                    const secondTypeName = secondRet != null ? secondRet.typeName : fallbackSecondType
                    const secondLine = secondRet != null ? secondRet.line : "?"
                    errors.push(new TSError(
                        "E-FN-007",
                        "E-FN-007: `fn " + fnName + "` returns `" + firstRet.typeName + "` in one branch " +
                        "(line " + firstRet.line + ") and `" + secondTypeName + "` in another " +
                        "(line " + secondLine + "). " +
                        "Declare an explicit union return type to allow this: " +
                        "`fn " + fnName + "(...) -> " + uniqueTypes.join(" | ") + " { ... }`. " +
                        "If the divergence is unintentional, make both branches return the same type.",
                        fnSpan,
                    ))
                }
            }
        }

        if (hasLiftInBody && !hasFnLocalTilde && liftSpan) {
            errors.push(new TSError(
                "E-FN-008",
                "E-FN-008: `lift` at line " + liftSpan.line + " inside `fn " + fnName + "` targets a " +
                "`~` accumulator initialized outside the `fn` boundary. " +
                "`lift` inside `fn` may only accumulate into `~` initialized within the same `fn` body.",
                liftSpan,
            ))
        }
    }

    // ---------------------------------------------------------------------------
    // Per-file processor
    // ---------------------------------------------------------------------------

    function processFile(fileAST, protectAnalysis, routeMap) {
        const errors = []

        const filePath = fileAST.filePath
        const fileSpan = { file: filePath, start: 0, end: 0, line: 1, col: 1 }

        const typeDecls = fileAST.typeDecls != null ? fileAST.typeDecls : []
        const typeRegistry = buildTypeRegistry(typeDecls, errors, fileSpan)

        const stateTypeRegistry = buildStateTypeRegistry()

        const generatedTypesByScopeId = new Map()

        if (protectAnalysis && protectAnalysis.views) {
            for (const [stateBlockId, dbTypeViews] of protectAnalysis.views) {
                if (!stateBlockId.startsWith(filePath + "::")) continue

                const spanStart = parseInt(stateBlockId.split("::")[1] != null ? stateBlockId.split("::")[1] : "0", 10)
                const blockSpan = { file: filePath, start: spanStart, end: spanStart, line: 1, col: 1 }

                const genResult = generateDbTypes(
                    dbTypeViews,
                    stateBlockId,
                    blockSpan,
                    typeRegistry,
                )

                for (const e of genResult.errors) errors.push(e)
                generatedTypesByScopeId.set(stateBlockId, genResult.generatedNames)
            }
        }

        const scopeChain = new ScopeChain()

        for (const [name, type] of typeRegistry) {
            if (!BUILTIN_TYPES.has(name)) {
                scopeChain.global.bind(name, { kind: "type", resolvedType: type })
            }
        }

        const nodeTypes = annotateNodes(
            fileAST,
            scopeChain,
            typeRegistry,
            routeMap,
            protectAnalysis,
            generatedTypesByScopeId,
            errors,
            stateTypeRegistry,
        )

        const linNodes = fileAST.linNodes != null ? fileAST.linNodes : []
        if (linNodes.length > 0) {
            checkLinear(linNodes, errors, { file: filePath })
        }

        const allNodes = fileAST.nodes != null ? fileAST.nodes : []
        if (allNodes.length > 0) {
            checkLoopControl(allNodes, errors, filePath)
        }

        const overloadRegistry = buildOverloadRegistry(fileAST)

        const typedAst = Object.assign({}, fileAST, {
            nodeTypes: nodeTypes,
            componentShapes: new Map(),
            scopeChain: scopeChain,
            stateTypeRegistry: stateTypeRegistry,
            overloadRegistry: overloadRegistry,
        })

        return { typedAst: typedAst, errors: errors }
    }

    // ---------------------------------------------------------------------------
    // Main entry point
    // ---------------------------------------------------------------------------

    export function runTS(input) {
        const files = input.files != null ? input.files : []
        const protectAnalysis = input.protectAnalysis != null ? input.protectAnalysis : { views: new Map() }
        const routeMap = input.routeMap != null ? input.routeMap : { functions: new Map() }

        const typedFiles = []
        const allErrors = []

        for (const fileAST of files) {
            const result = processFile(fileAST, protectAnalysis, routeMap)
            typedFiles.push(result.typedAst)
            for (const e of result.errors) allErrors.push(e)
        }

        return {
            files: typedFiles,
            errors: allErrors,
        }
    }
}
</program>
