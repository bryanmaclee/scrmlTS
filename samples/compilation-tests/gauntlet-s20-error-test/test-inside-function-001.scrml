// Phase 7: ~{} test block inside function (§19.12)
// Tests inside functions should be stripped from production.

${
  function add(a, b) {
    return a + b
  }
}

<p>Calculator</>

~{ "add function"
  test "adds two numbers" { assert add(2, 3) == 5 }
  test "handles zero" { assert add(0, 0) == 0 }
  test "handles negatives" { assert add(-1, 1) == 0 }
}
