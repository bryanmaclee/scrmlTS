// Phase 8: nested selectors inside #{} (CSS nesting)
// Should compile clean.

<div>
  #{
    .card {
      padding: 1rem;
      border: 1px solid #e5e7eb;

      .card-header {
        font-weight: 700;
        margin-bottom: 0.5rem;
      }

      .card-body {
        color: #4b5563;
      }

      &:hover {
        border-color: #3b82f6;
      }
    }
  }
  <div class="card">
    <div class="card-header">Title</>
    <div class="card-body">Content</>
  </div>
</div>
