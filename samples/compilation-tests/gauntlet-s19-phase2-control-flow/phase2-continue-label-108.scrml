// continue label
${
    let i = 0
    let j = 0
    let hits = 0
    outer: while (i < 3) {
        j = 0
        inner: while (j < 3) {
            if (j == 1) {
                j = j + 1
                continue outer
            }
            hits = hits + 1
            j = j + 1
        }
        i = i + 1
    }
    log(hits)
    function log(n: number) { let _ = n }
}
<program>
    <p>ok</>
</>
