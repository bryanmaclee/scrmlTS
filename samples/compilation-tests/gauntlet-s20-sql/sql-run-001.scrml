// Phase 6: ?{}.run() — write operation (§8.5.1)
// Should compile clean.

< db src="./test.db" tables="users">
${
  server function addUser(name, email) {
    let result = ?{`INSERT INTO users (name, email) VALUES (${name}, ${email})`}.run()
    return result
  }
}
<form onsubmit=addUser("Alice", "alice@test.com")>
  <button type="submit">Add</>
</form>
</>
