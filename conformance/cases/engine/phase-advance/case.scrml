${
    type PhaseTag:enum = { Idle, Loading, Done }
}
<engine for=PhaseTag initial=.Idle>
    <Idle rule=.Loading></>
    <Loading rule=.Done></>
    <Done rule=.Idle></>
</>
<program>
<button id="start" onclick=${@phaseTag = PhaseTag.Loading}>Start</>
<p id="phase">Phase: ${@phaseTag}</>
</program>
