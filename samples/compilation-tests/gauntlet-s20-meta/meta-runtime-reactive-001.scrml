// Phase 5 gauntlet: runtime meta — ^{} with @var forces runtime classification
// Should compile clean as runtime meta, NOT fire E-META-001.

<program>
${
  @theme = "dark"
}

<div>
  ^{
    if (meta.get("theme") == "dark") {
      meta.emit("<p>Dark mode</p>")
    } else {
      meta.emit("<p>Light mode</p>")
    }
  }
</div>
</program>
