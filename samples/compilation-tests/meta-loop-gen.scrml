// meta-loop-gen.scrml
// Use ^{} with emit() to generate a nav menu from a compile-time list.
// Tests: emit() inside a for-of loop producing a series of similar elements.

<program>

^{
    const navItems = [
        { label: "Home", href: "home" },
        { label: "About", href: "about" },
        { label: "Blog", href: "blog" },
        { label: "Contact", href: "contact" },
        { label: "Docs", href: "docs" }
    ]

    for (const item of navItems) {
        emit("<p class=nav-" + item.href + ">" + item.label + "</p>\n")
    }
}

</program>
