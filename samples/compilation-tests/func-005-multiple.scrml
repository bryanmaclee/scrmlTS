// func-005-multiple.scrml
// Multiple function declarations. Tests: several functions in one block.

<div>
    ${
        <count> = 0
        function increment() {
            @count = @count + 1
        }
        function decrement() {
            @count = @count - 1
        }
        function clearCount() {
            @count = 0
        }
    }
    <button onclick=increment()>+</>
    <button onclick=decrement()>-</>
    <button onclick=clearCount()>Reset</>
</div>
