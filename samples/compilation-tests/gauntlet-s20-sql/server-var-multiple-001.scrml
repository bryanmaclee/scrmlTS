// Phase 6: multiple server @var on same page — coalescing (§8.11)
// Should coalesce into __mountHydrate.

<program db="./test.db">
${
  server @userCount = ?{`SELECT COUNT(*) as count FROM users`}.get()
  server @postCount = ?{`SELECT COUNT(*) as count FROM posts`}.get()
  server @latestUser = ?{`SELECT name FROM users ORDER BY id DESC LIMIT 1`}.get()
}
<div>
  <p>Users: ${@userCount.count}</>
  <p>Posts: ${@postCount.count}</>
  <p>Latest: ${@latestUser.name}</>
</div>
</>
