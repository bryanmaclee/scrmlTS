${
    type Gate:enum = { Closed, Open }
    type GateMsg:enum = { Toggle }
}
<engine for=Gate initial=.Closed accepts=GateMsg>
    <Closed rule=.Open>
        | .Toggle :> .Open
    </>
    <Open rule=.Closed>
        | .Toggle :> .Closed
    </>
</>
<program>
<button id="toggle" onclick=@gate.advance(.Toggle)>Toggle</>
<p id="state">State: ${@gate}</>
</program>
