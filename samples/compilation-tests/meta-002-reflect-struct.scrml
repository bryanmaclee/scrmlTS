// meta-002-reflect-struct.scrml
// reflect(StructType) inside ^{} — compile-time introspection of a struct's
// field list. Emits one <li> per field at compile time.

<program>

${
    type UserProfile:struct = {
        username: string,
        email:    string,
        age:      number,
    }
}

<div>
    <h1>User Profile Fields</>
    <ul>
        ^{
            const info = reflect(UserProfile)
            for (const f of info.fields) {
                emit(`<li>${f.name}: <code>${f.type}</code></li>`)
            }
        }
    </ul>
</div>

</program>
