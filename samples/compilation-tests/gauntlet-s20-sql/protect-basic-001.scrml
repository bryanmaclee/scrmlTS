// Phase 6: protect= on db scope — E-PROTECT-003 (§11.3.5)
// Should compile clean — protected field excluded from client.

< db src="./test.db" protect="password_hash" tables="users">
${
  server function getUser(id) {
    return ?{`SELECT id, name, email FROM users WHERE id = ${id}`}.get()
  }
}
<div>
  <button onclick=getUser(1)>Load User</>
</div>
</>
