// partial match but all variants covered — W-MATCH-003
${
    type Status:enum = { Active, Pending }
    @status: Status = .Active
    function handle() {
        partial match @status {
            .Active  => log("a")
            .Pending => log("p")
        }
    }
    function log(s: string) { let _ = s }
}
<program>
    <p>ok</>
</>
