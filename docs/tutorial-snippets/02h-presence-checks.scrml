// 02h — Presence checks. `is not not`, `is some`, `not @var`. Always parenthesized.

<program>

${
  @user     = { name: "Ada" }
  @email    = "ada@example.com"
  @loggedIn = true
}

<div>
  <p if=(@user is not not)>User is present: ${@user.name}</p>
  <p if=(@email is some)>Email: ${@email}</p>
  <p if=(not @loggedIn)>Please sign in. (@loggedIn = ${@loggedIn})</p>
</div>

</program>
