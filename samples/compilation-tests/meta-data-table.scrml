// meta-data-table.scrml
// Use ^{} with emit() to generate a data table from compile-time config.
// Tests: emit() producing a complete table structure with headers and rows.

<program>

^{
    const columns = ["Name", "Role", "Status"]
    const rows = [
        ["Alice", "Engineer", "Active"],
        ["Bob", "Designer", "Active"],
        ["Carol", "PM", "On Leave"],
        ["Dave", "QA", "Active"]
    ]

    emit("<table class=data-table>\n")
    emit("  <thead>\n    <tr>\n")
    for (const col of columns) {
        emit("      <th>" + col + "</th>\n")
    }
    emit("    </tr>\n  </thead>\n")
    emit("  <tbody>\n")
    for (const row of rows) {
        emit("    <tr>\n")
        for (const cell of row) {
            emit("      <td>" + cell + "</td>\n")
        }
        emit("    </tr>\n")
    }
    emit("  </tbody>\n")
    emit("</table>\n")
}

</program>
