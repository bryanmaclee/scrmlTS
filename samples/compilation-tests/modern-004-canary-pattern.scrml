// modern-004-canary-pattern.scrml
// Compile-time emit() + ~{} test context canary. `lift` is markup-only (§22.9);
// meta blocks may not use lift — use emit() to splice markup at compile time.

<program>
<div class="app">
    ^{
        emit("<div>Dynamic content</div>")
    }
    <p>Static content</>
</>
</program>

~{ "canary"
    test "page loads" { assert true }
}
