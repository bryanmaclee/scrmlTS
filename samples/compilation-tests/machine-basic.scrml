// machine-basic — a reactive machine-governed enum, declared via external
// `< machine>` form (§51.5). Writes to the machine-bound reactive are
// gated by the declared transitions at runtime.
${
    type OrderStatus:enum = { Pending, Processing, Shipped, Delivered, Cancelled }

    @status: AdminFlow = OrderStatus.Pending

    function advance() {
        @status = OrderStatus.Processing
    }

    function ship() {
        @status = OrderStatus.Shipped
    }
}

< machine AdminFlow for OrderStatus>
    .Pending    => .Processing | .Cancelled
    .Processing => .Shipped | .Cancelled
    .Shipped    => .Delivered
    .Delivered  => .Pending
    .Cancelled  => .Pending
</>

<program>
<div>
    <h1>Order Status: ${@status}</>
    <button onclick=${advance()}>Advance</>
    <button onclick=${ship()}>Ship</>
</>
</program>
