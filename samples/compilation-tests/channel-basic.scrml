<program>
// §38 channel-basic.scrml — minimal WebSocket channel sample.
// See gauntlet-s20-channels/channel-basic-001.scrml for the gauntlet variant.
${
  @messages = []
  @status = "disconnected"
}

<div>
  <h1>Chat</>
  <p class="status">Status: ${@status}</>

  <channel name="chat"
           topic="general"
           onclient:open=onOpen()
           onclient:close=onClose()
           onserver:message=handleMsg(msg)>
  </>

  <ul>
    for (const msg of @messages) {
      <li>${msg}</>
    }
  </ul>
</>
</program>
