// control-015-try-catch.scrml
// Error handling via `!{}` (§19). scrml has no try/catch/finally — a failable
// call is followed by `!{ ::Variant(e) -> ... }` or propagated with `?`.

<div>
    ${
        function parseJson(src: string) {
            return JSON.parse(src)
        }

        let result = parseJson('{"key": "value"}')!{
            ::SyntaxError(e) -> "invalid"
            ::TypeError(e)   -> "bad type"
        }
    }
    <p>Parse attempted: ${result}</>
</div>
