// Phase 7: !{} inline catch handler (§19.4.3)
// Should compile clean.

${
  type LoadError:enum = { NotFound, Forbidden }

  function loadItem(id)! -> LoadError {
    if (id == 0) {
      fail LoadError.NotFound("no item")
    }
    return "item"
  }
}

<div>
${
  let item = loadItem(1) !{
    | ::NotFound(msg) -> "missing"
    | ::Forbidden -> "denied"
  }
}
<p>${item}</>
</div>
