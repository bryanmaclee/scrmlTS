// Phase 6: duplicate bound parameter (§8.2) — same expr used twice
// Should deduplicate into one ?N slot per unique expression.

< db src="./test.db" tables="logs">
${
  let userId = 42
  let row = ?{`SELECT * FROM logs WHERE created_by = ${userId} OR updated_by = ${userId}`}.get()
}
<p>Log loaded</>
</>
